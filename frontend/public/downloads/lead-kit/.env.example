# =============================================================================
# Lead Ingestion Automation Kit — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values before running.
# cp .env.example .env
# =============================================================================

# --- Webhook Security --------------------------------------------------------
# Optional. If set, all requests must include this value in the
# X-Webhook-Secret header. Disable by leaving empty.
WEBHOOK_SECRET=

# --- Google Sheets Integration -----------------------------------------------
# The ID from your Google Sheet URL:
#   https://docs.google.com/spreadsheets/d/{GOOGLE_SHEET_ID}/edit
GOOGLE_SHEET_ID=
# The tab/sheet name within the spreadsheet (will be created if missing)
GOOGLE_SHEET_NAME=Leads
# Path to your Google service account JSON key file.
# Download from GCP Console > IAM > Service Accounts > Keys
GOOGLE_CREDENTIALS_PATH=./credentials/google-service-account.json

# --- Notion Integration ------------------------------------------------------
# Notion Internal Integration Token.
# Create at: https://www.notion.so/my-integrations
NOTION_API_KEY=
# The Database ID from your Notion database URL:
#   https://www.notion.so/{workspace}/{NOTION_DATABASE_ID}?v=...
NOTION_DATABASE_ID=
# Max retry attempts for rate-limited Notion API calls
NOTION_MAX_RETRIES=5

# --- Slack Integration -------------------------------------------------------
# Incoming Webhook URL (simplest). Create at:
#   https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=
# Bot User OAuth Token for the Slack API (alternative to webhook).
# Create at: https://api.slack.com/apps > OAuth & Permissions
SLACK_TOKEN=
# Channel name or ID to post leads to (used with token-based auth)
SLACK_CHANNEL=#leads
# Default lead source label shown in Slack messages
SLACK_DEFAULT_SOURCE=Website Form

# --- Retry & Error Handling --------------------------------------------------
# Maximum number of delivery retry attempts per destination
MAX_RETRIES=3
# Base delay in milliseconds between retries (doubles each attempt)
RETRY_DELAY_MS=1000

# --- Redis (for docker-compose queue mode) -----------------------------------
# Redis connection URL for the job queue
REDIS_URL=redis://localhost:6379/0
