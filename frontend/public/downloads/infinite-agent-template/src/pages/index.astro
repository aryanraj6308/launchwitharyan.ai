---
import Layout from "@/layouts/Layout.astro";
import Hero from "@/components/Hero";
import Features from "@/components/Features";
import Testimonials from "@/components/Testimonials";
import Pricing from "@/components/Pricing";
import FAQ from "@/components/FAQ";
import CTA from "@/components/CTA";
import "@/styles/global.css";
---

<Layout
  title="InfiniteAgent — AI-Powered Automation Platform"
  description="Supercharge your workflow with AI agents that learn, adapt, and execute. The future of autonomous task management is here."
>
  <!-- Navigation bar -->
  <nav class="fixed top-0 left-0 right-0 z-50 glass border-b border-border/50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-2 font-display font-bold text-xl text-text-primary">
        <span class="w-8 h-8 rounded-lg bg-gradient-to-br from-gold-400 to-teal-500 flex items-center justify-center text-sm font-bold text-white">IA</span>
        InfiniteAgent
      </a>
      <div class="hidden md:flex items-center gap-8 text-sm font-medium text-text-secondary">
        <a href="#features" class="hover:text-text-primary transition-colors">Features</a>
        <a href="#testimonials" class="hover:text-text-primary transition-colors">Testimonials</a>
        <a href="#pricing" class="hover:text-text-primary transition-colors">Pricing</a>
        <a href="#faq" class="hover:text-text-primary transition-colors">FAQ</a>
      </div>
      <div class="flex items-center gap-3">
        <a href="#login" class="btn-ghost text-sm hidden sm:inline-flex">Sign In</a>
        <a href="#get-started" class="btn-primary text-sm">Get Started</a>
      </div>
    </div>
  </nav>

  <main>
    <Hero client:load />
    <Features client:load />
    <Testimonials client:load />
    <Pricing client:load />
    <FAQ client:load />
    <CTA client:load />
  </main>

  <!-- Footer -->
  <footer class="section border-t border-border">
    <div class="max-w-7xl mx-auto py-16">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-12">
        <div class="col-span-2 md:col-span-1">
          <a href="/" class="flex items-center gap-2 font-display font-bold text-lg text-text-primary mb-4">
            <span class="w-7 h-7 rounded-lg bg-gradient-to-br from-gold-400 to-teal-500 flex items-center justify-center text-xs font-bold text-white">IA</span>
            InfiniteAgent
          </a>
          <p class="text-sm text-text-muted leading-relaxed max-w-xs">
            Building the autonomous future of work, one agent at a time.
          </p>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-text-primary mb-4">Product</h4>
          <ul class="space-y-2.5 text-sm text-text-muted">
            <li><a href="#features" class="hover:text-text-primary transition-colors">Features</a></li>
            <li><a href="#pricing" class="hover:text-text-primary transition-colors">Pricing</a></li>
            <li><a href="#integrations" class="hover:text-text-primary transition-colors">Integrations</a></li>
            <li><a href="#changelog" class="hover:text-text-primary transition-colors">Changelog</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-text-primary mb-4">Company</h4>
          <ul class="space-y-2.5 text-sm text-text-muted">
            <li><a href="#about" class="hover:text-text-primary transition-colors">About</a></li>
            <li><a href="#blog" class="hover:text-text-primary transition-colors">Blog</a></li>
            <li><a href="#careers" class="hover:text-text-primary transition-colors">Careers</a></li>
            <li><a href="#contact" class="hover:text-text-primary transition-colors">Contact</a></li>
          </ul>
        </div>

        <div>
          <h4 class="text-sm font-semibold text-text-primary mb-4">Legal</h4>
          <ul class="space-y-2.5 text-sm text-text-muted">
            <li><a href="#privacy" class="hover:text-text-primary transition-colors">Privacy</a></li>
            <li><a href="#terms" class="hover:text-text-primary transition-colors">Terms</a></li>
            <li><a href="#security" class="hover:text-text-primary transition-colors">Security</a></li>
            <li><a href="#cookies" class="hover:text-text-primary transition-colors">Cookies</a></li>
          </ul>
        </div>
      </div>

      <div class="pt-8 border-t border-border flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-text-muted">
        <p>&copy; {new Date().getFullYear()} InfiniteAgent, Inc. All rights reserved.</p>
        <div class="flex items-center gap-4">
          <a href="https://twitter.com/infiniteagent" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors" aria-label="Twitter">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
          <a href="https://github.com/infiniteagent" target="_blank" rel="noopener noreferrer" class="hover:text-text-primary transition-colors" aria-label="GitHub">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          </a>
        </div>
      </div>
    </div>
  </footer>
</Layout>
