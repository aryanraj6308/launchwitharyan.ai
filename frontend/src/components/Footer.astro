---
import { ArrowUpRight } from 'lucide-react';
---

<footer class="relative z-10 border-t border-white/5 bg-darkbg pt-20 pb-10">
  <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_bottom,rgba(0,98,255,0.05),transparent_50%)] pointer-events-none"></div>
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-16">
      {/* Brand Column */}
      <div class="space-y-6">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 rounded-lg bg-gradient-to-tr from-primary to-accent-purple flex items-center justify-center font-bold text-white shadow-lg shadow-primary/20">
            L
          </div>
          <span class="font-display font-bold text-xl tracking-tight text-white">
            LaunchWithAryan<span class="text-primary">.AI</span>
          </span>
        </div>
        <p class="text-gray-400 text-sm leading-relaxed max-w-sm">
          We design and build bespoke high-performance web applications, custom AI automations, and intelligent chatbots for companies striving to lead in the digital era.
        </p>
        <div class="flex gap-4">
          <a href="https://x.com/aryanraj6308" target="_blank" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-colors duration-300">
            <span class="sr-only">Twitter</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4l11.733 16h4.267l-11.733 -16z"/><path d="M4 20l6.768 -6.768m2.46 -2.46l6.772 -6.772"/></svg>
          </a>
          <a href="https://linkedin.com/in/aryan-raj-59a9a5409" target="_blank" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-colors duration-300">
            <span class="sr-only">LinkedIn</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
          <a href="https://github.com/aryanraj6308" target="_blank" class="w-9 h-9 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-white/10 transition-colors duration-300">
            <span class="sr-only">GitHub</span>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
          </a>
        </div>
      </div>

      {/* Services */}
      <div>
        <h3 class="font-display font-semibold text-white mb-6 uppercase tracking-wider text-xs">Solutions</h3>
        <ul class="space-y-4">
          <li>
            <a href="/services" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              AI Automations <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
          <li>
            <a href="/services" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              Bespoke Web Development <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
          <li>
            <a href="/services" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              Intelligent Chatbots <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
          <li>
            <a href="/services" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              SEO Automation Engines <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
        </ul>
      </div>

      {/* Resources */}
      <div>
        <h3 class="font-display font-semibold text-white mb-6 uppercase tracking-wider text-xs">Store & Learning</h3>
        <ul class="space-y-4">
          <li>
            <a href="/store" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              AI Prompt Bundles <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
          <li>
            <a href="/store" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              Astro templates <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
          <li>
            <a href="/blog" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              SEO Insights & Blog <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
          <li>
            <a href="/portfolio" class="text-gray-400 hover:text-white text-sm transition-colors duration-300 flex items-center gap-1 group">
              Case Studies <ArrowUpRight class="w-3 h-3 opacity-0 group-hover:opacity-100 transition-opacity" />
            </a>
          </li>
        </ul>
      </div>

      {/* Newsletter */}
      <div>
        <h3 class="font-display font-semibold text-white mb-6 uppercase tracking-wider text-xs">Subscribe</h3>
        <p class="text-gray-400 text-sm mb-4 leading-relaxed">
          Stay updated with high-performance tech stack releases and AI strategies.
        </p>
        <form class="space-y-3" onsubmit="event.preventDefault(); alert('Subscribed!')">
          <div class="relative">
            <input
              type="email"
              placeholder="name@email.com"
              required
              class="w-full px-4 py-2.5 rounded-lg bg-white/5 border border-white/10 text-white placeholder-gray-500 focus:outline-none focus:border-primary/50 text-sm transition-colors"
            />
          </div>
          <button
            type="submit"
            class="w-full py-2.5 rounded-lg bg-primary hover:bg-primary-dark font-medium text-white text-sm transition-all duration-300"
          >
            Subscribe
          </button>
        </form>
      </div>
    </div>

    {/* Footer Bottom */}
    <div class="pt-8 border-t border-white/5 flex flex-col md:flex-row justify-between items-center gap-4 text-xs text-gray-500">
      <div>
        &copy; {new Date().getFullYear()} LaunchWithAryan.AI. All rights reserved.
      </div>
      <div class="flex gap-6">
        <a href="#" class="hover:text-white transition-colors">Privacy Policy</a>
        <a href="#" class="hover:text-white transition-colors">Terms of Service</a>
        <a href="#" class="hover:text-white transition-colors">Cookie Preferences</a>
      </div>
    </div>
  </div>
</footer>
