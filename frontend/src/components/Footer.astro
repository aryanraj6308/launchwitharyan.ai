---
const currentYear = new Date().getFullYear();
const footerLinks = [
  {
    heading: 'Services',
    links: [
      { label: 'AI Automation', href: '/services/ai-automation' },
      { label: 'Web Platforms', href: '/services/web-platforms' },
      { label: 'AI Chatbots', href: '/services/ai-bots' },
      { label: 'SEO Automation', href: '/services/seo-automation' },
    ],
  },
  {
    heading: 'Company',
    links: [
      { label: 'Pricing', href: '/pricing' },
      { label: 'Blog', href: '/blog' },
      { label: 'Contact', href: '/contact' },
    ],
  },
  {
    heading: 'Resources',
    links: [
      { label: 'AI Store', href: '/store' },
      { label: 'Dashboard', href: '/dashboard' },
      { label: 'Privacy Policy', href: '/privacy' },
      { label: 'Terms of Service', href: '/terms' },
      { label: 'DMCA', href: '/dmca' },
        { label: 'Admin', href: '/admin-dashboard' },
    ],
  },
];
---

<footer class="border-t border-default mt-32" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-10 lg:gap-12">
      <div class="col-span-2 md:col-span-1">
        <a href="/" class="block mb-4 w-fit" aria-label="AryanForge — Home">
          <img src="/logo.svg" alt="AryanForge logo" class="h-7 w-auto" width="28" height="28" />
        </a>
        <p class="text-sm text-secondary leading-relaxed max-w-[240px]">
          Premium AI automation and web development studio crafting enterprise-grade digital solutions.
        </p>
      </div>
      {footerLinks.map((group) => (
        <div>
          <h3 class="text-xs font-semibold text-primary uppercase tracking-widest mb-4">{group.heading}</h3>
          <ul class="space-y-2.5">
            {group.links.map((link) => (
              <li>
                <a href={link.href} class="text-sm text-secondary hover:text-primary transition-colors duration-150">
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 pt-8 border-t border-default flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs text-muted">
        &copy; {currentYear} AryanForge. All rights reserved.
      </p>
      <!-- AdSense Footer Ad Unit (placeholder) -->
      <div class="ad-container" style="display:none;">
        <ins class="adsbygoogle"
          style="display:inline-block;width:728px;height:90px"
          data-ad-client="ca-pub-xxxxxxxxxxxxxxxx"
          data-ad-slot="xxxxxxxxxx"></ins>
      </div>
    </div>
  </div>
</footer>
