---
const currentYear = new Date().getFullYear();
---

<footer class="relative border-t border-theme mt-24" role="contentinfo">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-12 gap-10 lg:gap-8">
      <div class="sm:col-span-2 lg:col-span-4">
        <a href="/" class="block mb-4 w-fit group" aria-label="LaunchWithAryan AI Home">
          <img src="/logo.svg" alt="LaunchWithAryan AI" class="h-8 w-auto" />
        </a>
        <p class="text-sm font-sans leading-relaxed text-theme-muted max-w-xs">
          Premium AI automation and web development studio crafting enterprise-grade digital solutions.
        </p>
      </div>
      <div class="lg:col-span-2">
        <h3 class="font-grotesk font-semibold text-sm text-theme-primary mb-4 uppercase tracking-widest">Services</h3>
        <ul class="space-y-3">
          <li><a href="/services#ai-automation" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">AI Automation</a></li>
          <li><a href="/services#web-dev" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">Web Development</a></li>
          <li><a href="/services#chatbots" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">AI Chatbots</a></li>
          <li><a href="/services#seo" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">SEO Automation</a></li>
        </ul>
      </div>
      <div class="lg:col-span-2">
        <h3 class="font-grotesk font-semibold text-sm text-theme-primary mb-4 uppercase tracking-widest">Company</h3>
        <ul class="space-y-3">
          <li><a href="/portfolio" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">Portfolio</a></li>
          <li><a href="/pricing" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">Pricing</a></li>
          <li><a href="/blog" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">Blog</a></li>
          <li><a href="/contact" class="text-sm font-sans text-theme-muted hover:text-gold transition-colors duration-200">Contact</a></li>
        </ul>
      </div>
      <div class="lg:col-span-4">
        <h3 class="font-grotesk font-semibold text-sm text-theme-primary mb-4 uppercase tracking-widest">Get In Touch</h3>
        <p class="text-sm font-sans text-theme-muted mb-4">Ready to build smarter? Let's talk.</p>
        <a href="/contact" class="inline-flex items-center gap-2 px-4 py-2.5 rounded-lg text-sm font-sans font-semibold text-darkbg bg-gradient-to-r from-gold to-gold-dim hover:opacity-90 transition-all duration-300">
          Start Your Project
        </a>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-theme flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-xs font-sans text-theme-muted">
        &copy; {currentYear} LaunchWithAryan AI. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-xs font-sans text-theme-muted hover:text-gold transition-colors duration-200">Privacy Policy</a>
        <a href="/terms" class="text-xs font-sans text-theme-muted hover:text-gold transition-colors duration-200">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
