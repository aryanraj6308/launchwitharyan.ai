---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.tsx';
import { ArrowRight, Bot, Cpu, Globe, Search, ShieldCheck, TrendingUp, Users } from 'lucide-react';

const stats = [
  { value: "10x", label: "Workflow Automation Speedup", icon: Cpu },
  { value: "99.9%", label: "Operational Reliability", icon: ShieldCheck },
  { value: "$2.4M+", label: "Saved for Enterprise Clients", icon: TrendingUp },
];

const highlights = [
  {
    title: "AI Automations & Agents",
    description: "Architecting custom LLM integrations, automatic data flows, and intelligent agent structures tailored to optimize operations.",
    icon: Bot,
    color: "from-blue-500/20 to-cyan-500/20 border-blue-500/30"
  },
  {
    title: "High-Performance Platforms",
    description: "Crafting beautiful luxury web platforms using Astro, React, and Three.js with ultra-fast Core Web Vitals.",
    icon: Globe,
    color: "from-purple-500/20 to-pink-500/20 border-purple-500/30"
  },
  {
    title: "SEO Automation Engines",
    description: "Automating structured schema generation, sitemaps, and organic content pipelines to maximize Google traffic.",
    icon: Search,
    color: "from-emerald-500/20 to-teal-500/20 border-emerald-500/30"
  }
];

const faqs = [
  {
    q: "How does the AI chatbot integration work?",
    a: "We deploy custom chatbot components that link to secure REST endpoints. The backend can route inquiries to OpenAI APIs or local Ollama instances (e.g. running Llama-3/Mistral models) based on privacy and cost requirements."
  },
  {
    q: "Are the digital templates in the AI Store customizable?",
    a: "Absolutely. Every prompt, layout, and automation kit sold in our store comes with clean configuration files, structured READMEs, and TypeScript support, making integration straightforward."
  },
  {
    q: "What is your setup for security and data privacy?",
    a: "All FastAPI backend routes feature rate-limiting and robust security middleware. We design RAG databases with strict auth controls, preventing database exposure."
  }
];
---

<Layout title="LaunchWithAryan AI | Bespoke AI Automations & Premium Websites">
  
  {/* Hero Section */}
  <Hero client:load />

  {/* Metrics Section */}
  <section class="py-20 border-y border-white/5 bg-white/2 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
        {stats.map((stat) => {
          const Icon = stat.icon;
          return (
            <div class="glassmorphism p-8 rounded-2xl border border-white/5 flex flex-col items-center text-center space-y-4 hover:border-white/10 transition-colors">
              <div class="p-4 rounded-xl bg-white/5 text-primary">
                <Icon class="w-8 h-8" />
              </div>
              <div class="text-4xl font-display font-bold text-white">{stat.value}</div>
              <div class="text-sm text-gray-400 font-sans">{stat.label}</div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* Core Features / Services Showcase */}
  <section class="py-24 lg:py-32 relative">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
        <h2 class="text-3xl sm:text-4xl font-display font-bold text-white">
          Architected for <span class="gradient-text-cyan">Maximum Impact</span>
        </h2>
        <p class="text-gray-400 font-sans leading-relaxed">
          We combine cutting-edge AI integrations with clean engineering to build digital tools that reduce overhead and accelerate scaling.
        </p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {highlights.map((feat) => {
          const Icon = feat.icon;
          return (
            <div class={`glassmorphism-interactive p-8 rounded-2xl flex flex-col justify-between space-y-6 relative overflow-hidden group`}>
              <div class="space-y-4">
                <div class="p-3.5 rounded-xl bg-white/5 text-white w-fit group-hover:scale-105 transition-transform duration-300">
                  <Icon class="w-6 h-6 text-primary" />
                </div>
                <h3 class="text-xl font-display font-semibold text-white">{feat.title}</h3>
                <p class="text-sm text-gray-400 leading-relaxed font-sans">{feat.description}</p>
              </div>
              <a href="/services" class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary hover:text-white transition-colors pt-4 group">
                Learn More <ArrowRight class="w-4 h-4 group-hover:translate-x-1 transition-transform" />
              </a>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  {/* FAQ Section */}
  <section class="py-24 lg:py-32 border-t border-white/5 relative bg-white/1">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 space-y-4">
        <h2 class="text-3xl font-display font-bold text-white">Frequently Asked Questions</h2>
        <p class="text-gray-400 text-sm font-sans">Everything you need to know about our premium AI systems</p>
      </div>

      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="glassmorphism p-6 sm:p-8 rounded-2xl border border-white/5 space-y-3">
            <h3 class="text-lg font-display font-medium text-white flex items-start gap-3">
              <span class="text-primary font-bold">Q:</span>
              {faq.q}
            </h3>
            <p class="text-sm text-gray-400 leading-relaxed font-sans pl-7">
              {faq.a}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  {/* CTA Section */}
  <section class="py-24 border-t border-white/5 relative overflow-hidden bg-gradient-to-b from-transparent to-primary/5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-8 relative z-10">
      <h2 class="text-3xl sm:text-5xl font-display font-bold text-white tracking-tight leading-tight">
        Ready to Launch Your <br class="sm:hidden" />
        <span class="gradient-text">AI Automation Strategy?</span>
      </h2>
      <p class="text-gray-400 font-sans max-w-xl mx-auto leading-relaxed">
        Join leading enterprises leverage intelligent agent workflows and custom web platforms to scale operations exponentially.
      </p>
      <div class="flex justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 px-8 py-4 rounded-full bg-primary hover:bg-primary-dark font-sans font-semibold text-white transition-all duration-300 hover:shadow-lg hover:shadow-primary/30"
        >
          Book a Discovery Call
          <ArrowRight class="w-5 h-5" />
        </a>
      </div>
    </div>
  </section>

</Layout>
