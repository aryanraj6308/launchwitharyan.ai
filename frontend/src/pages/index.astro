---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.tsx';
import { Rocket, Bot, Globe, TrendingUp, Shield, Zap, ArrowRight, CheckCircle, Clock, DollarSign, Users, BarChart3 } from 'lucide-react';

const services = [
  { icon: Bot, title: "AI Automation Workflows", desc: "Custom AI agents that automate lead gen, support tickets, data entry, and reporting. Save 10x time with enterprise-grade reliability.", accent: "from-gold to-gold-dim" },
  { icon: Globe, title: "Premium Web Platforms", desc: "High-performance websites built with Astro + React. Blazing fast, SEO-optimized, accessibility-first, with WCAG AA compliance.", accent: "from-teal to-teal-dim" },
  { icon: Rocket, title: "AI Conversational Bots", desc: "Intelligent chatbots with RAG, tone-aware memory, and deep analytics. Deploy across web, WhatsApp, and Slack.", accent: "from-gold to-gold-dim" },
  { icon: TrendingUp, title: "SEO Automation Engine", desc: "AI-driven content strategy, auto-blog generation, SERP analysis, and backlink intelligence. Outrank your competition.", accent: "from-teal to-teal-dim" },
];

const caseStudies = [
  { icon: Clock, title: "StreamLogix — 70% Ticket Automation", result: "Automated customer support with AI agents handling 70% of incoming tickets. Response time dropped from 4h to 90s.", metric: "70%", metricLabel: "Automated" },
  { icon: DollarSign, title: "Opal Studio — 40% Conversion Lift", result: "Built a sub-800ms SSR platform with intelligent caching. Mobile conversions jumped 40% in 30 days.", metric: "40%", metricLabel: "Conversion Lift" },
  { icon: Users, title: "NexGen Data — 85% Workflow Speedup", result: "Automated data pipeline with AI agents. Processing time went from 6h to 45min per report.", metric: "85%", metricLabel: "Faster" },
];

const pricingPlans = [
  { name: "Starter", price: "$2,499", desc: "Best for startups launching their first AI workflow.", features: ["1 AI workflow or landing page", "Basic CRM + WhatsApp bot integration", "SEO-optimized (on-page)", "1 revision round", "2-week delivery"], popular: false },
  { name: "Growth", price: "$4,999", desc: "For growing teams scaling operations with AI.", features: ["3 AI workflows or multi-page site", "Full CRM + WhatsApp bot + analytics", "AI content generation (5 posts/mo)", "3 revision rounds", "3-week delivery", "Priority support"], popular: true },
  { name: "Enterprise", price: "$9,999+", desc: "Custom solutions for large-scale deployments.", features: ["Unlimited AI workflows", "Custom integrations & API access", "Dedicated project manager", "SLA-backed uptime guarantee", "Security audit & penetration test", "Ongoing optimization"], popular: false },
];

const faqs = [
  { q: "What does an AI automation workflow include?", a: "Every workflow includes strategy design, AI agent development, integration with your existing tools, testing, and deployment. We use a combination of LLMs, vector databases, and custom logic to ensure reliability." },
  { q: "How long does a typical project take?", a: "Starter projects are delivered in 2 weeks. Growth projects take 3 weeks. Enterprise solutions are scoped during discovery — most complete within 4–6 weeks." },
  { q: "Do I need technical knowledge to get started?", a: "Not at all. We handle everything from strategy to deployment. You'll receive a dashboard to monitor performance, and we provide ongoing support." },
  { q: "What platforms do you integrate with?", a: "We integrate with Shopify, WordPress, Salesforce, HubSpot, Slack, WhatsApp, Telegram, Stripe, Razorpay, Google Analytics, and more through custom API connectors." },
  { q: "Is my data secure?", a: "Yes. We implement 7-layer backend security: SSTI/SQLi/LPDOS/ReDoS protection, brute-force lockout, clipboard attack prevention, JWT nonce verification, and HMAC-signed webhooks. All data is encrypted in transit and at rest." },
  { q: "What happens after launch?", a: "We provide 30 days of post-launch monitoring and support. For ongoing optimization, we offer maintenance plans including AI model retraining, content updates, and performance tuning." },
];
---

<Layout>
  <Hero client:load />

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="services">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">What We Build</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Full-Stack <span class="gradient-gold">AI & Web</span> Services
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">
        From custom AI agents to premium web platforms — we deliver production-ready digital infrastructure.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {services.map((s) => (
        <article class="glass rounded-2xl p-6 lg:p-8 card-hover" itemScope itemType="https://schema.org/Service">
          <div class={`w-11 h-11 rounded-xl bg-gradient-to-br ${s.accent} flex items-center justify-center mb-5 shadow-lg`}>
            <s.icon class="w-5 h-5 text-darkbg" />
          </div>
          <h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-3" itemProp="name">{s.title}</h3>
          <p class="font-sans text-sm text-theme-secondary leading-relaxed" itemProp="description">{s.desc}</p>
          <a href="/contact" class="inline-flex items-center gap-1.5 mt-5 text-sm font-sans font-medium text-gold hover:text-gold-light transition-colors duration-200">
            Learn More <ArrowRight class="w-3.5 h-3.5" />
          </a>
          <meta itemProp="provider" content="LaunchWithAryan AI" />
        </article>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="process">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">How It Works</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        From Idea to <span class="gradient-gold">Launch</span>
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">
        A proven 4-step process that delivers results — on time and on budget.
      </p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8 relative">
      <div class="hidden lg:block absolute top-10 left-[12.5%] right-[12.5%] h-[1px] bg-gradient-to-r from-gold/40 via-gold/20 to-transparent" aria-hidden="true" />
      {[
        { step: "01", title: "Discovery", desc: "We deep-dive into your business goals, audience, and technical requirements." },
        { step: "02", title: "Architecture", desc: "Full technical blueprint with security audit, performance targets, and UX roadmap." },
        { step: "03", title: "Build & Iterate", desc: "Agile sprints with weekly demos. You see progress every step of the way." },
        { step: "04", title: "Deploy & Scale", desc: "Production launch with monitoring, CI/CD, and ongoing optimization." },
      ].map((p) => (
        <div key={p.step} class="text-center relative z-10">
          <div class="w-16 h-16 rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center mx-auto mb-5">
            <span class="font-grotesk font-bold text-lg text-gold">{p.step}</span>
          </div>
          <h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">{p.title}</h3>
          <p class="font-sans text-sm text-theme-muted leading-relaxed max-w-[220px] mx-auto">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="relative overflow-hidden" id="results">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
      <div class="text-center mb-16 space-y-4">
        <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Proven Results</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          Real Outcomes For <span class="gradient-gold">Real Businesses</span>
        </h2>
        <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">
          Measurable results from clients who trusted us with their AI automation and web infrastructure.
        </p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {caseStudies.map((c, i) => (
          <article class="glass rounded-2xl p-8 card-hover" key={i}>
            <div class="flex items-center gap-4 mb-5">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-gold to-gold-dim flex items-center justify-center">
                <c.icon class="w-5 h-5 text-darkbg" />
              </div>
              <div>
                <div class="text-2xl font-grotesk font-bold text-gold">{c.metric}</div>
                <div class="text-xs font-sans text-theme-muted uppercase tracking-wider">{c.metricLabel}</div>
              </div>
            </div>
            <h3 class="font-grotesk font-semibold text-base text-theme-primary mb-3">{c.title}</h3>
            <p class="font-sans text-sm text-theme-secondary leading-relaxed">{c.result}</p>
          </article>
        ))}
      </div>
      <div class="mt-12 glass rounded-3xl p-8 lg:p-14 grid grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12 text-center border-theme">
        <div>
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold">150+</div>
          <div class="text-sm font-sans text-theme-muted mt-2 uppercase tracking-wider">Projects Delivered</div>
        </div>
        <div>
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold">99.9%</div>
          <div class="text-sm font-sans text-theme-muted mt-2 uppercase tracking-wider">Uptime Achieved</div>
        </div>
        <div>
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold">4.9★</div>
          <div class="text-sm font-sans text-theme-muted mt-2 uppercase tracking-wider">Client Rating</div>
        </div>
        <div>
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold">85%</div>
          <div class="text-sm font-sans text-theme-muted mt-2 uppercase tracking-wider">Avg. Efficiency Gain</div>
        </div>
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="pricing">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Investment</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Transparent <span class="gradient-gold">Pricing</span>
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">
        Fixed-price packages with no hidden fees. Every plan includes deployment and 30-day support.
      </p>
    </div>
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 max-w-5xl mx-auto">
      {pricingPlans.map((plan) => (
        <div class={`relative glass rounded-2xl p-8 lg:p-10 card-hover ${plan.popular ? 'border-gold/40 ring-1 ring-gold/30' : 'border-theme'}`}>
          {plan.popular && (
            <span class="absolute -top-3 left-1/2 -translate-x-1/2 px-4 py-1 rounded-full text-xs font-sans font-semibold text-darkbg bg-gradient-to-r from-gold to-gold-dim">
              Most Popular
            </span>
          )}
          <h3 class="font-grotesk font-semibold text-xl text-theme-primary">{plan.name}</h3>
          <div class="mt-4 mb-2">
            <span class="text-3xl lg:text-4xl font-grotesk font-bold text-theme-primary">{plan.price}</span>
            {plan.name !== 'Enterprise' && <span class="text-sm font-sans text-theme-muted"> / project</span>}
          </div>
          <p class="text-sm font-sans text-theme-muted mb-8">{plan.desc}</p>
          <ul class="space-y-3 mb-10">
            {plan.features.map((f, i) => (
              <li key={i} class="flex items-start gap-3 text-sm font-sans text-theme-secondary">
                <CheckCircle class="w-4 h-4 text-gold shrink-0 mt-0.5" />
                {f}
              </li>
            ))}
          </ul>
          <a href="/contact" class={`block text-center py-3 px-6 rounded-xl text-sm font-semibold font-sans transition-all duration-300 ${plan.popular ? 'btn-primary justify-center' : 'btn-secondary justify-center'}`}>
            Get Started
          </a>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="faq">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">FAQ</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Questions? <span class="gradient-gold">Answered.</span>
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">
        Everything you need to know before getting started.
      </p>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-card" key={i}>
          <summary>{faq.q}</summary>
          <div class="faq-answer">{faq.a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="contact">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Contact</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Let's Build <span class="gradient-gold">Something Great</span>
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">
        Tell us about your project. We'll get back to you within 24 hours with a tailored proposal.
      </p>
    </div>
    <div class="max-w-2xl mx-auto glass rounded-3xl p-8 lg:p-12 border-theme">
      <form action="/api/contact" method="POST" class="space-y-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
          <div>
            <label for="name" class="block text-sm font-sans font-medium text-theme-primary mb-2">Full Name</label>
            <input type="text" id="name" name="name" required placeholder="Your name"
              class="w-full px-4 py-3 rounded-xl bg-theme-elevated border border-theme text-theme-primary text-sm font-sans placeholder:text-theme-muted/60 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-all duration-200" />
          </div>
          <div>
            <label for="email" class="block text-sm font-sans font-medium text-theme-primary mb-2">Email Address</label>
            <input type="email" id="email" name="email" required placeholder="you@company.com"
              class="w-full px-4 py-3 rounded-xl bg-theme-elevated border border-theme text-theme-primary text-sm font-sans placeholder:text-theme-muted/60 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-all duration-200" />
          </div>
        </div>
        <div>
          <label for="service" class="block text-sm font-sans font-medium text-theme-primary mb-2">Service Needed</label>
          <select id="service" name="service"
            class="w-full px-4 py-3 rounded-xl bg-theme-elevated border border-theme text-theme-primary text-sm font-sans focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-all duration-200">
            <option value="">Select a service...</option>
            <option value="ai-automation">AI Automation Workflows</option>
            <option value="web-platform">Premium Web Platform</option>
            <option value="chatbot">AI Conversational Bot</option>
            <option value="seo">SEO Automation Engine</option>
            <option value="other">Other / Not Sure</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-sans font-medium text-theme-primary mb-2">Project Details</label>
          <textarea id="message" name="message" rows={4} required placeholder="Tell us about your project, goals, and timeline..."
            class="w-full px-4 py-3 rounded-xl bg-theme-elevated border border-theme text-theme-primary text-sm font-sans placeholder:text-theme-muted/60 focus:outline-none focus:border-gold focus:ring-1 focus:ring-gold/30 transition-all duration-200 resize-y"></textarea>
        </div>
        <button type="submit" class="btn-primary w-full justify-center text-base py-3.5">
          Send Proposal Request <ArrowRight class="w-4 h-4" />
        </button>
        <p class="text-xs font-sans text-theme-muted text-center">
          We respect your privacy. No spam, no sharing your info.
        </p>
      </form>
    </div>
  </section>
</Layout>

<style is:global>
  @keyframes pulseSlow { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.35; } }
  @keyframes drift3 { 0%, 100% { transform: translate(0, 0); } 25% { transform: translate(12px, -8px); } 50% { transform: translate(-6px, -12px); } 75% { transform: translate(-8px, 6px); } }
  @keyframes bounceGentle { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-10px); } }
</style>
