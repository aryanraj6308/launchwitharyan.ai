---
import Layout from '../layouts/Layout.astro';
import AdminDashboard from '../components/AdminDashboard.tsx';
---

<Layout title="Admin Dashboard | AryanForge">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10 lg:py-14">
    <div class="mb-8">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-2">Secure Admin</p>
      <h1 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        AI <span class="gradient-gold">Operations</span> Dashboard
      </h1>
      <p class="text-sm text-secondary mt-2">Monitor live conversations, leads, and AI performance.</p>
    </div>

    <AdminDashboard client:only="react" />
  </section>
</Layout>
