---
import Layout from '../layouts/Layout.astro';
import StoreCatalog from '../components/Store.tsx';
---

<Layout title="AI Products & Digital Store | LaunchWithAryan AI">
  <section class="relative overflow-hidden py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      {/* Page Header */}
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs text-gray-300 backdrop-blur-md">
          <span>Digital Templates Catalog</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-display font-bold text-white tracking-tight">
          Accelerate Your Build With <span class="gradient-text">Premium Kits</span>
        </h1>
        <p class="text-gray-400 font-sans leading-relaxed text-base">
          Unlock pre-configured, production-ready developer templates, secure AI configurations, and prompt scripts to scale your technology stack.
        </p>
      </div>

      {/* React Interactive Store Component */}
      <StoreCatalog client:load />

    </div>
  </section>
</Layout>
