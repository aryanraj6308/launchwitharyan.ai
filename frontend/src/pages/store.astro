---
import Layout from '../layouts/Layout.astro';
import StoreCatalog from '../components/Store.tsx';
---

<Layout title="AI Products & Digital Store | LaunchWithAryan AI">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="text-center max-w-3xl mx-auto mb-16">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Digital Products</p>
      <h1 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Premium <span class="gradient-gold">Digital Assets</span></h1>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Download premium AI templates, prompt packs, and automation kits designed by our engineering team.</p>
    </div>

    <StoreCatalog client:load />
  </section>
</Layout>

<script is:inline src="https://checkout.razorpay.com/v1/checkout.js"></script>
