---
import Layout from '../layouts/Layout.astro';
import { ArrowUpRight, Cpu, Eye, BarChart, ExternalLink } from 'lucide-react';

const projects = [
  {
    id: "synthetix-agent",
    title: "Synthetix LLM Sentiment Engine",
    client: "Synthetix Capital LLC",
    type: "AI Automation",
    metrics: "94% Accuracy in Sentiment Trends",
    desc: "Designed and engineered an automated research parser that ingests financial transcripts, news wires, and social APIs, storing contextual embeddings in a PGVector cluster to stream market reports.",
    tech: ["FastAPI", "Python", "Llama-3", "PostgreSQL PGVector"],
    gradient: "from-blue-600/10 via-cyan-600/5 to-transparent"
  },
  {
    id: "linear-ux-platform",
    title: "Linear-UX Corporate Architecture",
    client: "Linear Labs Europe",
    type: "Premium Web App",
    metrics: "100/100 Core Web Vitals Score",
    desc: "A bespoke, highly optimized static storefront utilizing Astro, React and custom WebGL shaders to deliver fluid screen transitions and under-50ms paint load speeds.",
    tech: ["Astro", "React", "Three.js", "GSAP", "Tailwind"],
    gradient: "from-purple-600/10 via-pink-600/5 to-transparent"
  },
  {
    id: "realtime-crm-sync",
    title: "Supabase Realtime CRM Integrations",
    client: "Veritas Automation",
    type: "Enterprise Workflow",
    metrics: "450+ Hours Saved Per Month",
    desc: "Integrated legacy HubSpot & Salesforce databases into a unified central Supabase dashboard with custom rate-limiting queues, secure JWT profiles, and automatic Slack notifications.",
    tech: ["FastAPI", "Supabase", "React Table", "OAuth2"],
    gradient: "from-emerald-600/10 via-teal-600/5 to-transparent"
  }
];
---

<Layout title="Premium Client Case Studies | LaunchWithAryan AI">
  
  <section class="relative overflow-hidden py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      {/* Page Header */}
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-xs text-gray-300 backdrop-blur-md">
          <span>Client Showcase</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-display font-bold text-white tracking-tight">
          Systems Engineered For <span class="gradient-text">High Performance</span>
        </h1>
        <p class="text-gray-400 font-sans leading-relaxed text-base">
          Browse through select products, AI agents, and corporate website infrastructures we have designed and built for our enterprise client portfolio.
        </p>
      </div>

      {/* Projects list */}
      <div class="space-y-12 mb-20">
        {projects.map((project) => (
          <div class={`glassmorphism p-8 sm:p-12 rounded-3xl border border-white/5 bg-gradient-to-r ${project.gradient} hover:border-white/10 transition-all duration-300 relative overflow-hidden group`}>
            
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
              {/* Text Specs */}
              <div class="lg:col-span-8 space-y-6">
                <div class="flex flex-wrap items-center gap-3">
                  <span class="px-2.5 py-1 rounded-full bg-white/5 border border-white/10 text-[10px] font-semibold text-accent-cyan uppercase tracking-wider">
                    {project.type}
                  </span>
                  <span class="text-xs text-gray-500 font-medium">For {project.client}</span>
                </div>

                <h2 class="text-2xl sm:text-3xl font-display font-bold text-white group-hover:text-primary transition-colors">
                  {project.title}
                </h2>

                <p class="text-gray-400 text-sm sm:text-base leading-relaxed font-sans max-w-3xl">
                  {project.desc}
                </p>

                {/* Tech Badges */}
                <div class="flex flex-wrap gap-2 pt-2">
                  {project.tech.map((t) => (
                    <span class="px-3 py-1 rounded-lg bg-white/2 border border-white/5 text-xs text-gray-400 font-mono">
                      {t}
                    </span>
                  ))}
                </div>
              </div>

              {/* Metrics & Action */}
              <div class="lg:col-span-4 lg:border-l lg:border-white/5 lg:pl-8 flex flex-col justify-between h-full space-y-6">
                <div class="space-y-2">
                  <span class="text-xs text-gray-500 uppercase tracking-wider font-semibold font-sans">Business Impact</span>
                  <div class="text-lg sm:text-xl font-bold text-white font-display flex items-center gap-2">
                    <BarChart class="w-5 h-5 text-primary flex-shrink-0" />
                    {project.metrics}
                  </div>
                </div>

                <div class="flex gap-4">
                  <a
                    href="/contact"
                    class="inline-flex items-center justify-center gap-2 w-full sm:w-auto px-5 py-3 rounded-xl bg-primary hover:bg-primary-dark font-sans text-xs font-semibold text-white transition-all duration-300"
                  >
                    Discuss Similar Project
                    <ArrowUpRight class="w-4 h-4" />
                  </a>
                </div>
              </div>
            </div>

          </div>
        ))}
      </div>

    </div>
  </section>

</Layout>
