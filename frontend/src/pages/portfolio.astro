---
import Layout from '../layouts/Layout.astro';
import { ArrowUpRight, BarChart } from 'lucide-react';

const projects = [
  {
    id: "synthetix-agent",
    title: "Synthetix LLM Sentiment Engine",
    client: "Synthetix Capital LLC",
    type: "AI Automation",
    metrics: "94% Accuracy in Sentiment Trends",
    desc: "Designed and engineered an automated research parser that ingests financial transcripts, news wires, and social APIs, storing contextual embeddings in a PGVector cluster to stream market reports.",
    tech: ["FastAPI", "Python", "Llama-3", "PostgreSQL PGVector"],
  },
  {
    id: "linear-ux-platform",
    title: "Linear-UX Corporate Architecture",
    client: "Linear Labs Europe",
    type: "Premium Web App",
    metrics: "100/100 Core Web Vitals Score",
    desc: "A bespoke, highly optimized static storefront utilizing Astro, React and custom WebGL shaders to deliver fluid screen transitions and under-50ms paint load speeds.",
    tech: ["Astro", "React", "Three.js", "GSAP", "Tailwind"],
  },
  {
    id: "realtime-crm-sync",
    title: "Supabase Realtime CRM Integrations",
    client: "Veritas Automation",
    type: "Enterprise Workflow",
    metrics: "450+ Hours Saved Per Month",
    desc: "Integrated legacy HubSpot & Salesforce databases into a unified central Supabase dashboard with custom rate-limiting queues, secure JWT profiles, and automatic Slack notifications.",
    tech: ["FastAPI", "Supabase", "React Table", "OAuth2"],
  }
];
---

<Layout title="Premium Client Case Studies | LaunchWithAryan AI">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Client Showcase</p>
      <h1 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Systems Engineered For <span class="gradient-gold">High Performance</span>
      </h1>
      <p class="text-base text-secondary mt-3">Browse through select products, AI agents, and corporate website infrastructures we have designed and built for our enterprise client portfolio.</p>
    </div>

    <div class="space-y-6">
      {projects.map((project) => (
        <div class="card card-hover p-7 lg:p-9 relative overflow-hidden">
          <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-center">
            <div class="lg:col-span-5 order-2 lg:order-1">
              <div class="rounded-xl overflow-hidden border border-default">
                <img src="/images/portfolio-project.svg" alt={project.title} class="w-full h-auto" loading="lazy" />
              </div>
            </div>

            <div class="lg:col-span-7 order-1 lg:order-2 space-y-5">
              <div class="flex flex-wrap items-center gap-3">
                <span class="px-2 py-0.5 rounded-md bg-raised border border-default text-[10px] font-medium text-gold uppercase tracking-wider">
                  {project.type}
                </span>
                <span class="text-xs text-muted">For {project.client}</span>
              </div>

              <h2 class="text-xl sm:text-2xl font-grotesk font-bold text-primary">
                {project.title}
              </h2>

              <p class="text-sm text-secondary leading-relaxed max-w-3xl">
                {project.desc}
              </p>

              <div class="flex flex-wrap gap-2">
                {project.tech.map((t) => (
                  <span class="px-2.5 py-1 rounded-lg bg-raised border border-default text-xs text-secondary">
                    {t}
                  </span>
                ))}
              </div>

              <div class="flex items-center gap-4 pt-2">
                <div class="flex items-center gap-2 text-sm text-primary">
                  <BarChart class="w-4 h-4 text-gold" />
                  <span class="font-medium">{project.metrics}</span>
                </div>
                <a href="/contact" class="inline-flex items-center gap-1.5 text-sm font-medium text-gold hover:text-gold-dim transition-colors ml-auto">
                  Discuss Similar Project <ArrowUpRight class="w-4 h-4" />
                </a>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
</Layout>
