---
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.tsx';
import { MessageSquare, Brain, Globe, BarChart3, Users, Languages, PhoneCall, Database, ArrowRight, CheckCircle, Star, Zap } from 'lucide-react';

const features = [
  { icon: Brain, title: "RAG Memory", desc: "Retrieval-Augmented Generation with vector databases. Your bot remembers past conversations and retrieves relevant context instantly." },
  { icon: Database, title: "Smart Knowledge Base", desc: "Connect documentation, FAQs, product catalogs, and internal wikis. AI finds answers across all your sources." },
  { icon: Globe, title: "WhatsApp Integration", desc: "Deploy your AI bot on WhatsApp Business API. Automated support and lead qualification via the world's most popular messaging platform." },
  { icon: MessageSquare, title: "Website Chatbot", desc: "Embeddable chatbot widget with custom styling, proactive messaging, and seamless handoff to human agents." },
  { icon: Users, title: "Human Handoff", desc: "Smart escalation to human agents when needed. Context is preserved — no repeating information." },
  { icon: BarChart3, title: "Analytics Dashboard", desc: "Track conversations, satisfaction scores, resolution rates, and revenue attribution in real-time." },
  { icon: Languages, title: "Multi-Language", desc: "Speak your customers' language. Support for 50+ languages with automatic detection." },
  { icon: PhoneCall, title: "Lead Generation", desc: "Qualify leads, book meetings, and capture contact info through natural conversation flows." },
];

const process = [
  { step: "01", title: "Knowledge Ingestion", desc: "We index your docs, FAQs, and data into a vector database for fast retrieval." },
  { step: "02", title: "Persona Design", desc: "Craft your bot's tone, personality, and response style to match your brand." },
  { step: "03", title: "Bot Development", desc: "Build the AI agent with RAG, context windows, and conversation flows." },
  { step: "04", title: "Channel Deployment", desc: "Deploy on website, WhatsApp, Slack, or all channels simultaneously." },
  { step: "05", title: "Monitor & Improve", desc: "Analyze conversations, identify gaps, and continuously improve accuracy." },
];

const benefits = [
  { icon: Users, value: "70%", label: "Auto-Resolution Rate", desc: "Most queries resolved without human intervention." },
  { icon: Zap, value: "90s", label: "Avg. Response Time", desc: "From 4 hours to 90 seconds — instant customer support." },
  { icon: BarChart3, value: "3x", label: "Lead Conversion", desc: "AI-qualified leads convert at 3x the rate of cold outreach." },
  { icon: Globe, value: "24/7", label: "Always Available", desc: "Round-the-clock support across all time zones." },
];

const faqs = [
  { q: "How accurate is the AI chatbot?", a: "With RAG and a well-structured knowledge base, accuracy exceeds 95% for known topics. The system learns from each interaction." },
  { q: "Can it handle complex customer queries?", a: "Yes. The AI understands context, maintains conversation state, and can access multiple knowledge sources simultaneously." },
  { q: "What happens when the AI doesn't know the answer?", a: "It gracefully hands off to a human agent with full conversation context — no repetition needed." },
  { q: "Which platforms can I deploy on?", a: "Website embed, WhatsApp Business API, Slack, Telegram, and custom API integrations for any platform." },
  { q: "How long does setup take?", a: "Basic setup takes 1 week. Full deployment with custom knowledge base and multi-channel support takes 2-3 weeks." },
  { q: "Is customer data secure?", a: "All conversations are encrypted. Data stays within your infrastructure. We offer on-premise deployment options for regulated industries." },
];

const testimonials = [
  { quote: "The AI bot handles 70% of our support tickets autonomously. Our team can focus on complex issues that actually need human expertise.", author: "Sarah Chen", role: "CTO, StreamLogix" },
  { quote: "WhatsApp bot integration was seamless. Our customers love the instant responses. Satisfaction scores are up 35%.", author: "Rahul Mehta", role: "CEO, ShopFlow" },
];
---

<Layout title="AI Conversational Bots | LaunchWithAryan AI"
  description="Deploy intelligent AI chatbots with RAG memory, context awareness, analytics, and human-like conversations across web, WhatsApp, and Slack.">

  <ServiceHero title="AI Chatbots That Actually" highlight="Understand Customers."
    desc="Deploy intelligent AI bots with memory, context awareness, analytics, and human-like conversations. 24/7 support across web, WhatsApp, and Slack."
    badge="AI Chatbot Service">

    <div class="relative w-full h-[320px] sm:h-[400px] lg:h-[460px] flex items-center justify-center">
      <div class="absolute w-72 h-72 rounded-full blur-[100px] opacity-20 glow-hero-primary pointer-events-none" />
      <div class="absolute w-48 h-48 rounded-full blur-[80px] opacity-15 top-[20%] right-[5%] glow-hero-teal pointer-events-none" />
      <svg viewBox="0 0 400 420" class="w-full h-full max-w-[420px]">
        <defs>
          <linearGradient id="bg" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#d4a843" /><stop offset="100%" stop-color="#b89038" />
          </linearGradient>
          <linearGradient id="bt" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#14b8a6" /><stop offset="100%" stop-color="#0d9488" />
          </linearGradient>
        </defs>
        <rect x="30" y="30" width="340" height="350" rx="24" fill="var(--bg-glass)" stroke="url(#bg)" stroke-width="1" opacity="0.9"/>
        <rect x="55" y="55" width="290" height="60" rx="16" fill="var(--bg-elevated)" stroke="var(--border-color)" stroke-width="0.5"/>
        <circle cx="78" cy="85" r="16" fill="url(#bg)" opacity="0.8"/>
        <text x="78" y="90" text-anchor="middle" fill="#0a0a0b" font-size="12" font-weight="700">AI</text>
        <text x="108" y="81" fill="var(--text-primary)" font-size="13" font-weight="700" font-family="Inter,sans-serif">Aryan Assistant</text>
        <text x="108" y="98" fill="var(--text-muted)" font-size="10">Online  ·  Responds instantly</text>
        <rect x="70" y="135" width="200" height="40" rx="12" fill="url(#bt)" opacity="0.15"/>
        <text x="85" y="160" fill="var(--text-primary)" font-size="11" font-family="Inter,sans-serif">Hi! How can I help you today? 👋</text>
        <rect x="130" y="185" width="180" height="40" rx="12" fill="var(--bg-elevated)" stroke="var(--border-color)" stroke-width="0.5"/>
        <text x="145" y="210" fill="var(--text-primary)" font-size="11" font-family="Inter,sans-serif">I need help with my order</text>
        <rect x="70" y="235" width="210" height="55" rx="12" fill="url(#bt)" opacity="0.15"/>
        <text x="85" y="255" fill="var(--text-primary)" font-size="11" font-family="Inter,sans-serif">Sure! Let me check your order status.</text>
        <text x="85" y="275" fill="var(--text-muted)" font-size="10" font-family="Inter,sans-serif">I've found order #4821 — it's out for delivery 🚚</text>
        <rect x="130" y="300" width="160" height="40" rx="12" fill="var(--bg-elevated)" stroke="var(--border-color)" stroke-width="0.5"/>
        <text x="145" y="325" fill="var(--text-primary)" font-size="11" font-family="Inter,sans-serif">Perfect, thank you! 🙏</text>
        <rect x="55" y="355" width="290" height="1" fill="var(--border-color)"/>
      </svg>
    </div>
  </ServiceHero>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">What We Build</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Intelligent <span class="gradient-gold">Conversation</span>
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">AI chatbots with memory, context, and human-like understanding — deployed across every channel your customers use.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">💬 Support Bot</h3><p class="text-sm font-sans text-theme-secondary">Resolve 70%+ of support tickets instantly with AI that understands your products and policies.</p></div>
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">💰 Sales Bot</h3><p class="text-sm font-sans text-theme-secondary">Qualify leads, answer product questions, and book meetings — all through natural conversation.</p></div>
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">📋 Onboarding Bot</h3><p class="text-sm font-sans text-theme-secondary">Guide new users through setup, answer questions, and reduce time-to-value for your product.</p></div>
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">🔍 FAQ Bot</h3><p class="text-sm font-sans text-theme-secondary">Instant answers to common questions from your knowledge base — always up to date, always accurate.</p></div>
    </div>
  </section>

  <section class="relative overflow-hidden py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 space-y-4">
        <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Features</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          Enterprise <span class="gradient-gold">Conversation AI</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((f, i) => (
          <div key={i} class="glass rounded-2xl p-6 lg:p-8 card-hover">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-gold to-gold-dim flex items-center justify-center mb-5 shadow-lg">
              <f.icon class="w-5 h-5 text-darkbg" />
            </div>
            <h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-3">{f.title}</h3>
            <p class="text-sm font-sans text-theme-secondary leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">How It Works</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Knowledge to <span class="gradient-gold">Conversation</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 relative max-w-5xl mx-auto">
      <div class="hidden lg:block absolute top-8 left-[10%] right-[10%] h-[1px] bg-gradient-to-r from-gold/40 via-gold/20 to-transparent" aria-hidden="true" />
      {process.map((p, i) => (
        <div key={i} class="text-center relative z-10">
          <div class="w-14 h-14 rounded-full bg-gold/10 border border-gold/20 flex items-center justify-center mx-auto mb-4">
            <span class="font-grotesk font-bold text-base text-gold">{p.step}</span>
          </div>
          <h3 class="font-grotesk font-semibold text-base text-theme-primary mb-2">{p.title}</h3>
          <p class="text-xs font-sans text-theme-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Impact</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Results That <span class="gradient-gold">Speak Volumes</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((b, i) => (
        <div key={i} class="glass rounded-2xl p-8 text-center card-hover">
          <b.icon class="w-8 h-8 text-gold mx-auto mb-4" />
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold mb-1">{b.value}</div>
          <div class="text-sm font-sans font-semibold text-theme-primary mb-2">{b.label}</div>
          <p class="text-xs font-sans text-theme-muted">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Testimonials</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          What Clients <span class="gradient-gold">Say</span>
        </h2>
      </div>
      <div class="space-y-6">
        {testimonials.map((t, i) => (
          <div key={i} class="glass rounded-2xl p-6 border-theme">
            <div class="flex gap-1 mb-3">{Array(5).fill(0).map((_,j) => <Star key={j} class="w-4 h-4 fill-gold text-gold" />)}</div>
            <p class="text-sm font-sans text-theme-secondary leading-relaxed italic">&ldquo;{t.quote}&rdquo;</p>
            <div class="mt-3 text-sm"><span class="font-semibold text-theme-primary">{t.author}</span><span class="text-theme-muted"> — {t.role}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="faq">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">FAQ</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">Questions? <span class="gradient-gold">Answered.</span></h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-card" key={i}><summary>{faq.q}</summary><div class="faq-answer">{faq.a}</div></details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="glass rounded-3xl p-10 lg:p-16 text-center border-theme relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none bg-gradient-to-br from-gold/5 via-transparent to-teal/5" aria-hidden="true" />
      <div class="relative z-10 space-y-6">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          Ready to <span class="gradient-gold">Deploy</span> Your AI Bot?
        </h2>
        <p class="text-lg font-sans text-theme-secondary max-w-xl mx-auto">Let's build a chatbot that your customers will love. Free consultation included.</p>
        <a href="/contact" class="btn-primary inline-flex">Start Your Project <ArrowRight class="w-4 h-4" /></a>
      </div>
    </div>
  </section>
</Layout>
