---
import Layout from '../../layouts/Layout.astro';
import { MessageSquare, Brain, Globe, BarChart3, Users, Languages, PhoneCall, Database, ArrowRight } from 'lucide-react';

const features = [
  { icon: Brain, title: "RAG Memory", desc: "Retrieval-Augmented Generation with vector databases. Your bot remembers past conversations and retrieves relevant context instantly." },
  { icon: Database, title: "Smart Knowledge Base", desc: "Connect documentation, FAQs, product catalogs, and internal wikis. AI finds answers across all your sources." },
  { icon: Globe, title: "WhatsApp Integration", desc: "Deploy your AI bot on WhatsApp Business API. Automated support and lead qualification via the world's most popular messaging platform." },
  { icon: MessageSquare, title: "Website Chatbot", desc: "Embeddable chatbot widget with custom styling, proactive messaging, and seamless handoff to human agents." },
  { icon: Users, title: "Human Handoff", desc: "Smart escalation to human agents when needed. Context is preserved — no repeating information." },
  { icon: BarChart3, title: "Analytics Dashboard", desc: "Track conversations, satisfaction scores, resolution rates, and revenue attribution in real-time." },
  { icon: Languages, title: "Multi-Language", desc: "Speak your customers' language. Support for 50+ languages with automatic detection." },
  { icon: PhoneCall, title: "Lead Generation", desc: "Qualify leads, book meetings, and capture contact info through natural conversation flows." },
];

const process = [
  { step: "01", title: "Knowledge Ingestion", desc: "We index your docs, FAQs, and data into a vector database for fast retrieval." },
  { step: "02", title: "Persona Design", desc: "Craft your bot's tone, personality, and response style to match your brand." },
  { step: "03", title: "Bot Development", desc: "Build the AI agent with RAG, context windows, and conversation flows." },
  { step: "04", title: "Channel Deployment", desc: "Deploy on website, WhatsApp, Slack, or all channels simultaneously." },
  { step: "05", title: "Monitor & Improve", desc: "Analyze conversations, identify gaps, and continuously improve accuracy." },
];

const benefits = [
  { icon: Users, value: "70%", label: "Auto-Resolution Rate", desc: "Most queries resolved without human intervention." },
  { icon: BarChart3, value: "90s", label: "Avg. Response Time", desc: "From 4 hours to 90 seconds — instant customer support." },
  { icon: MessageSquare, value: "3x", label: "Lead Conversion", desc: "AI-qualified leads convert at 3x the rate of cold outreach." },
  { icon: Globe, value: "24/7", label: "Always Available", desc: "Round-the-clock support across all time zones." },
];

const faqs = [
  { q: "How accurate is the AI chatbot?", a: "With RAG and a well-structured knowledge base, accuracy exceeds 95% for known topics. The system learns from each interaction." },
  { q: "Can it handle complex customer queries?", a: "Yes. The AI understands context, maintains conversation state, and can access multiple knowledge sources simultaneously." },
  { q: "What happens when the AI doesn't know the answer?", a: "It gracefully hands off to a human agent with full conversation context — no repetition needed." },
  { q: "Which platforms can I deploy on?", a: "Website embed, WhatsApp Business API, Slack, Telegram, and custom API integrations for any platform." },
  { q: "How long does setup take?", a: "Basic setup takes 1 week. Full deployment with custom knowledge base and multi-channel support takes 2-3 weeks." },
  { q: "Is customer data secure?", a: "All conversations are encrypted. Data stays within your infrastructure. We offer on-premise deployment options for regulated industries." },
];
---

<Layout title="AI Conversational Bots | LaunchWithAryan AI"
  description="Deploy intelligent AI chatbots with RAG memory, context awareness, analytics, and human-like conversations across web, WhatsApp, and Slack.">

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">AI Chatbot Service</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight leading-[1.1] text-primary">
        AI Chatbots That Actually <span class="gradient-gold">Understand Customers.</span>
      </h1>
      <p class="text-base sm:text-lg text-secondary mt-4 max-w-2xl">
        Deploy intelligent AI bots with memory, context awareness, analytics, and human-like conversations. 24/7 support across web, WhatsApp, and Slack.
      </p>
      <a href="/contact?type=quick" class="btn-primary text-base inline-flex mt-6">
        Start Your Project <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Intelligent <span class="gradient-gold">Conversation</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">AI chatbots with memory, context, and human-like understanding — deployed across every channel your customers use.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((f, i) => (
        <div key={i} class="card card-hover p-6 lg:p-7">
          <div class="w-10 h-10 rounded-xl bg-raised border border-default flex items-center justify-center text-gold mb-4">
            <f.icon class="w-5 h-5" />
          </div>
          <h3 class="font-grotesk font-semibold text-lg text-primary mb-3">{f.title}</h3>
          <p class="text-sm text-secondary leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Knowledge to <span class="gradient-gold">Conversation</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">From raw data to intelligent dialogue — our proven process delivers production-ready AI chatbots.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 relative max-w-5xl mx-auto">
      <div class="hidden lg:block absolute top-6 left-[10%] right-[10%] h-px bg-gradient-to-r from-gold/40 via-gold/20 to-transparent" aria-hidden="true" />
      {process.map((p, i) => (
        <div key={i} class="text-center relative z-10">
          <div class="w-12 h-12 rounded-full bg-raised border border-default flex items-center justify-center mx-auto mb-4">
            <span class="font-grotesk font-bold text-sm text-primary">{p.step}</span>
          </div>
          <h3 class="font-grotesk font-semibold text-base text-primary mb-2">{p.title}</h3>
          <p class="text-xs text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Impact</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Results That <span class="gradient-gold">Speak</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Real metrics from real deployments — see what AI chatbots deliver for our clients.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((b, i) => (
        <div key={i} class="card card-hover p-6 lg:p-7 text-center">
          <b.icon class="w-8 h-8 text-gold mx-auto mb-4" />
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold mb-1">{b.value}</div>
          <div class="text-sm font-grotesk font-semibold text-primary mb-2">{b.label}</div>
          <p class="text-xs text-muted">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20" id="faq">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">FAQ</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Questions? <span class="gradient-gold">Answered.</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Everything you need to know about our AI chatbot service.</p>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-card" key={i}><summary>{faq.q}</summary><div class="faq-answer">{faq.a}</div></details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="card card-hover p-10 lg:p-14 text-center border-gold/20 max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Ready to <span class="gradient-gold">Deploy</span> Your AI Bot?</h2>
      <p class="text-base text-secondary mt-4 max-w-xl mx-auto">Let's build a chatbot that your customers will love. Free consultation included.</p>
      <a href="/contact?type=quick" class="btn-primary inline-flex mt-6">Start Your Project <ArrowRight class="w-4 h-4 ml-2" /></a>
    </div>
  </section>
</Layout>
