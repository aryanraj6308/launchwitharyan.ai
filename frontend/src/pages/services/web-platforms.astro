---
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.tsx';
import { Globe, Zap, Search, BarChart3, Smartphone, Palette, Code, Shield, ArrowRight, CheckCircle, Clock, TrendingUp, Users, Star } from 'lucide-react';

const features = [
  { icon: Zap, title: "Lightning Fast", desc: "Sub-100ms load times with edge-optimized SSR, intelligent caching, and CDN-first asset delivery." },
  { icon: Search, title: "SEO Optimized", desc: "Built-in meta management, structured data, sitemaps, and Core Web Vitals optimization for top rankings." },
  { icon: Shield, title: "WCAG Accessible", desc: "Full AA compliance — keyboard navigation, screen reader support, contrast ratios, and reduced motion." },
  { icon: Palette, title: "Premium UI/UX", desc: "Award-winning design system with micro-animations, glassmorphism, and seamless interactions." },
  { icon: Smartphone, title: "Responsive Design", desc: "Pixel-perfect across every device — from mobile to 4K desktop, with touch-optimized interactions." },
  { icon: Globe, title: "Conversion Optimized", desc: "Data-driven CRO with heatmaps, A/B testing infrastructure, and psychology-based copywriting." },
  { icon: Code, title: "Modern Stack", desc: "Astro, React, Next.js, Tailwind, Framer Motion, GSAP — the latest tech for maximum performance." },
  { icon: BarChart3, title: "CMS Integration", desc: "Headless CMS, Sanity, Strapi, or WordPress — you choose. Easy content management with live preview." },
];

const showcase = [
  { title: "SaaS Landing Page", tag: "4.2s → 0.8s load time", desc: "Complete redesign with Astro + React island architecture. Lighthouse score jumped from 62 to 98." },
  { title: "E-Commerce Platform", tag: "40% conversion lift", desc: "Premium Shopify headless store with AI product recommendations and real-time inventory sync." },
  { title: "Enterprise Dashboard", tag: "99.9% uptime", desc: "Real-time analytics dashboard with multi-tenant architecture, RBAC, and sub-second queries." },
];

const tech = [
  { name: "Astro", color: "from-orange-500 to-red-500" },
  { name: "React", color: "from-sky-400 to-blue-500" },
  { name: "Next.js", color: "from-zinc-700 to-zinc-900" },
  { name: "Tailwind", color: "from-cyan-400 to-blue-400" },
  { name: "GSAP", color: "from-green-400 to-emerald-500" },
  { name: "Framer", color: "from-pink-400 to-rose-500" },
  { name: "Three.js", color: "from-violet-400 to-purple-500" },
  { name: "TypeScript", color: "from-blue-400 to-indigo-500" },
];

const faqs = [
  { q: "How long does it take to build a premium website?", a: "A standard 5-page site takes 2-3 weeks. Complex platforms with custom functionality take 4-8 weeks depending on scope." },
  { q: "Will my website be fast?", a: "We guarantee sub-2 second load times on mobile 3G. Most sites ship under 800ms with 95+ Lighthouse scores." },
  { q: "Can I update the content myself?", a: "Yes. We integrate a headless CMS (Sanity, Strapi, or your choice) so you can edit text, images, and pages without touching code." },
  { q: "Do you provide ongoing maintenance?", a: "Absolutely. We offer maintenance plans that include security updates, performance monitoring, content updates, and 24/7 support." },
  { q: "Is the website SEO-ready from day one?", a: "Yes. Every site ships with structured data, meta management, optimized Core Web Vitals, auto-sitemaps, and Google Search Console setup." },
  { q: "What if I need to add features later?", a: "Our modular architecture makes adding features straightforward. New pages, sections, or integrations can be added without rebuilding." },
];

const testimonials = [
  { quote: "The website they built loads in under 800ms on mobile. Conversions jumped 40% within the first month.", author: "Marcus Webb", role: "Founder, Opal Studio" },
  { quote: "Our Lighthouse score went from 62 to 98. The design is absolutely stunning — clients constantly compliment it.", author: "Elena Torres", role: "CEO, Luxe Digital" },
  { quote: "Working with LaunchWithAryan was seamless. They understood our brand vision immediately and delivered beyond expectations.", author: "James Park", role: "CTO, Meridian AI" },
];
---

<Layout title="Premium Web Platforms | LaunchWithAryan AI"
  description="High-performance websites built with Astro, React, and Next.js. Blazing fast, SEO-optimized, accessibility-first, with WCAG AA compliance.">

  <ServiceHero title="High-Performance Websites" highlight="Built To Convert."
    desc="Create blazing fast, SEO-ready, premium websites designed for growth. Sub-second load times, stunning design, and conversion-optimized flows."
    badge="Web Development Service">

    <div class="relative w-full h-[320px] sm:h-[400px] lg:h-[460px] flex items-center justify-center">
      <div class="absolute w-72 h-72 rounded-full blur-[100px] opacity-20 glow-hero-primary pointer-events-none" />
      <svg viewBox="0 0 420 420" class="w-full h-full max-w-[440px]">
        <defs>
          <linearGradient id="wg" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#d4a843" /><stop offset="100%" stop-color="#b89038" />
          </linearGradient>
          <linearGradient id="wt" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#14b8a6" /><stop offset="100%" stop-color="#0d9488" />
          </linearGradient>
        </defs>
        <rect x="40" y="60" width="340" height="260" rx="20" fill="var(--bg-glass)" stroke="url(#wg)" stroke-width="1" opacity="0.9"/>
        <rect x="60" y="85" width="60" height="14" rx="7" fill="url(#wg)" opacity="0.6"/>
        <rect x="130" y="85" width="80" height="14" rx="7" fill="var(--bg-elevated)" stroke="var(--border-color)" stroke-width="0.5"/>
        <rect x="60" y="115" width="140" height="8" rx="4" fill="var(--text-muted)" opacity="0.3"/>
        <rect x="60" y="130" width="160" height="8" rx="4" fill="var(--text-muted)" opacity="0.2"/>
        <rect x="60" y="155" width="300" height="100" rx="10" fill="var(--bg-elevated)" stroke="var(--border-color)" stroke-width="0.5"/>
        <rect x="75" y="170" width="40" height="40" rx="8" fill="url(#wt)" opacity="0.3"/>
        <rect x="125" y="175" width="80" height="8" rx="4" fill="var(--text-muted)" opacity="0.4"/>
        <rect x="125" y="190" width="120" height="6" rx="3" fill="var(--text-muted)" opacity="0.2"/>
        <rect x="75" y="222" width="40" height="40" rx="8" fill="url(#wg)" opacity="0.2"/>
        <rect x="125" y="227" width="60" height="8" rx="4" fill="var(--text-muted)" opacity="0.4"/>
        <rect x="125" y="242" width="100" height="6" rx="3" fill="var(--text-muted)" opacity="0.2"/>
        <rect x="310" y="85" width="50" height="22" rx="11" fill="url(#wg)" opacity="0.8"/>
        <text x="335" y="100" text-anchor="middle" fill="#0a0a0b" font-size="9" font-weight="700" font-family="Inter,sans-serif">LIVE</text>
        <rect x="60" y="275" width="90" height="10" rx="5" fill="url(#wg)" opacity="0.3"/>
        <rect x="160" y="275" width="60" height="10" rx="5" fill="var(--text-muted)" opacity="0.15"/>
        <rect x="40" y="335" width="340" height="30" rx="15" fill="var(--bg-glass)" stroke="url(#wt)" stroke-width="0.5" opacity="0.7"/>
        <circle cx="70" cy="350" r="8" fill="url(#wg)" opacity="0.6"/>
        <circle cx="95" cy="350" r="8" fill="var(--text-muted)" opacity="0.2"/>
        <circle cx="120" cy="350" r="8" fill="var(--text-muted)" opacity="0.2"/>
      </svg>
    </div>
  </ServiceHero>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">What We Build</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Premium <span class="gradient-gold">Web Platforms</span>
      </h2>
      <p class="text-lg font-sans text-theme-secondary max-w-2xl mx-auto">Every site is crafted with performance, accessibility, and conversion as core pillars.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">📄 Landing Pages</h3><p class="text-sm font-sans text-theme-secondary">High-converting single-page sites with premium animations and optimized form flows.</p></div>
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">🏪 E-Commerce</h3><p class="text-sm font-sans text-theme-secondary">Headless storefronts with AI recommendations, fast checkout, and real-time inventory.</p></div>
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">📊 Dashboards</h3><p class="text-sm font-sans text-theme-secondary">Real-time analytics with multi-tenant architecture, RBAC, and sub-second queries.</p></div>
      <div class="glass rounded-2xl p-6 lg:p-8 card-hover"><h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-2">🌐 Multi-Page Sites</h3><p class="text-sm font-sans text-theme-secondary">Full websites with CMS, blog, SEO infrastructure, and scalable architecture.</p></div>
    </div>
  </section>

  <section class="relative overflow-hidden py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16 space-y-4">
        <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Features</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          Built for <span class="gradient-gold">Performance & Growth</span>
        </h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
        {features.map((f, i) => (
          <div key={i} class="glass rounded-2xl p-6 lg:p-8 card-hover">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-gold to-gold-dim flex items-center justify-center mb-5 shadow-lg">
              <f.icon class="w-5 h-5 text-darkbg" />
            </div>
            <h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-3">{f.title}</h3>
            <p class="text-sm font-sans text-theme-secondary leading-relaxed">{f.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Our Work</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Premium <span class="gradient-gold">Showcase</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      {showcase.map((s, i) => (
        <div key={i} class="glass rounded-2xl p-8 card-hover">
          <span class="inline-block px-2.5 py-1 rounded-full bg-gold/10 text-xs font-semibold text-gold mb-4">{s.tag}</span>
          <h3 class="font-grotesk font-semibold text-lg text-theme-primary mb-3">{s.title}</h3>
          <p class="text-sm font-sans text-theme-secondary leading-relaxed">{s.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Tech Stack</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Modern <span class="gradient-gold">Technology</span>
      </h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-4 max-w-4xl mx-auto">
      {tech.map((t) => (
        <div key={t.name} class="glass rounded-xl p-4 text-center card-hover">
          <div class={`w-9 h-9 rounded-lg bg-gradient-to-br ${t.color} flex items-center justify-center mx-auto mb-2`}>
            <span class="text-xs font-bold text-white">{t.name[0]}</span>
          </div>
          <div class="text-xs font-sans text-theme-muted">{t.name}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div class="space-y-6">
        <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">Testimonials</span>
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          Trusted by <span class="gradient-gold">Leading Brands</span>
        </h2>
      </div>
      <div class="space-y-6">
        {testimonials.map((t, i) => (
          <div key={i} class="glass rounded-2xl p-6 border-theme">
            <div class="flex gap-1 mb-3">{Array(5).fill(0).map((_,j) => <Star key={j} class="w-4 h-4 fill-gold text-gold" />)}</div>
            <p class="text-sm font-sans text-theme-secondary leading-relaxed italic">&ldquo;{t.quote}&rdquo;</p>
            <div class="mt-3 text-sm"><span class="font-semibold text-theme-primary">{t.author}</span><span class="text-theme-muted"> — {t.role}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32" id="faq">
    <div class="text-center mb-16 space-y-4">
      <span class="inline-block text-xs font-sans font-medium tracking-[0.2em] uppercase text-gold">FAQ</span>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
        Questions? <span class="gradient-gold">Answered.</span>
      </h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-card" key={i}><summary>{faq.q}</summary><div class="faq-answer">{faq.a}</div></details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 lg:py-32">
    <div class="glass rounded-3xl p-10 lg:p-16 text-center border-theme relative overflow-hidden">
      <div class="absolute inset-0 pointer-events-none bg-gradient-to-br from-gold/5 via-transparent to-teal/5" aria-hidden="true" />
      <div class="relative z-10 space-y-6">
        <h2 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight text-theme-primary">
          Ready to <span class="gradient-gold">Launch</span> Your Site?
        </h2>
        <p class="text-lg font-sans text-theme-secondary max-w-xl mx-auto">Let's build a website that grows your business. Free consultation included.</p>
        <a href="/contact" class="btn-primary inline-flex">Start Your Project <ArrowRight class="w-4 h-4" /></a>
      </div>
    </div>
  </section>
</Layout>
