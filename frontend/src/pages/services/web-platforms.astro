---
import Layout from '../../layouts/Layout.astro';
import { Globe, Zap, Search, BarChart3, Smartphone, Palette, Code, Shield, ArrowRight } from 'lucide-react';

const features = [
  { icon: Zap, title: "Lightning Fast", desc: "Sub-100ms load times with edge-optimized SSR, intelligent caching, and CDN-first asset delivery." },
  { icon: Search, title: "SEO Optimized", desc: "Built-in meta management, structured data, sitemaps, and Core Web Vitals optimization for top rankings." },
  { icon: Shield, title: "WCAG Accessible", desc: "Full AA compliance — keyboard navigation, screen reader support, contrast ratios, and reduced motion." },
  { icon: Palette, title: "Premium UI/UX", desc: "Award-winning design system with micro-animations, glassmorphism, and seamless interactions." },
  { icon: Smartphone, title: "Responsive Design", desc: "Pixel-perfect across every device — from mobile to 4K desktop, with touch-optimized interactions." },
  { icon: Globe, title: "Conversion Optimized", desc: "Data-driven CRO with heatmaps, A/B testing infrastructure, and psychology-based copywriting." },
  { icon: Code, title: "Modern Stack", desc: "Astro, React, Next.js, Tailwind, Framer Motion, GSAP — the latest tech for maximum performance." },
  { icon: BarChart3, title: "CMS Integration", desc: "Headless CMS, Sanity, Strapi, or WordPress — you choose. Easy content management with live preview." },
];

const process = [
  { step: "01", title: "SEO Audit", desc: "Full site audit covering technical SEO, content gaps, and competitor landscape." },
  { step: "02", title: "Keyword Strategy", desc: "AI identifies high-opportunity keywords clustered by intent and search volume." },
  { step: "03", title: "Content Engine", desc: "Auto-generate optimized content at scale with AI writing and structured data." },
  { step: "04", title: "Technical Fixes", desc: "Automated implementation of technical SEO improvements and Core Web Vitals." },
  { step: "05", title: "Monitor & Grow", desc: "Continuous SERP tracking, backlink monitoring, and strategy refinement." },
];

const benefits = [
  { icon: Globe, value: "300%", label: "Traffic Growth", desc: "Average traffic increase within 6 months of launching your premium web platform." },
  { icon: Search, value: "850+", label: "Keywords Ranked", desc: "Average number of keywords our clients rank for in the top 10 positions." },
  { icon: Zap, value: "10x", label: "Content Output", desc: "Generate 10x more optimized content without increasing headcount." },
  { icon: BarChart3, value: "40%", label: "Conversion Uplift", desc: "Better traffic quality and optimized pages drive measurable conversion gains." },
];

const faqs = [
  { q: "How long does it take to build a premium website?", a: "A standard 5-page site takes 2-3 weeks. Complex platforms with custom functionality take 4-8 weeks depending on scope." },
  { q: "Will my website be fast?", a: "We guarantee sub-2 second load times on mobile 3G. Most sites ship under 800ms with 95+ Lighthouse scores." },
  { q: "Can I update the content myself?", a: "Yes. We integrate a headless CMS (Sanity, Strapi, or your choice) so you can edit text, images, and pages without touching code." },
  { q: "Do you provide ongoing maintenance?", a: "Absolutely. We offer maintenance plans that include security updates, performance monitoring, content updates, and 24/7 support." },
  { q: "Is the website SEO-ready from day one?", a: "Yes. Every site ships with structured data, meta management, optimized Core Web Vitals, auto-sitemaps, and Google Search Console setup." },
  { q: "What if I need to add features later?", a: "Our modular architecture makes adding features straightforward. New pages, sections, or integrations can be added without rebuilding." },
];
---

<Layout title="Premium Web Platforms | AryanForge"
  description="High-performance websites built with Astro, React, and Next.js. Blazing fast, SEO-optimized, accessibility-first, with WCAG AA compliance.">

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Web Development Service</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight leading-[1.1] text-primary">
        High-Performance Websites <span class="gradient-gold">Built To Convert.</span>
      </h1>
      <p class="text-base sm:text-lg text-secondary mt-4 max-w-2xl">
        Create blazing fast, SEO-ready, premium websites designed for growth. Sub-second load times, stunning design, and conversion-optimized flows.
      </p>
      <a href="/contact?type=premium" class="btn-primary text-base inline-flex mt-6">
        Start Your Project <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Premium <span class="gradient-gold">Web Platforms</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Every site is crafted with performance, accessibility, and conversion as core pillars.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((f, i) => (
        <div key={i} class="card card-hover p-6 lg:p-7">
          <div class="w-10 h-10 rounded-xl bg-raised border border-default flex items-center justify-center text-gold mb-4">
            <f.icon class="w-5 h-5" />
          </div>
          <h3 class="font-grotesk font-semibold text-lg text-primary mb-3">{f.title}</h3>
          <p class="text-sm text-secondary leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Audit to <span class="gradient-gold">Dominance</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">From concept to launch — a repeatable process for building premium web platforms that rank and convert.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 relative max-w-5xl mx-auto">
      <div class="hidden lg:block absolute top-6 left-[10%] right-[10%] h-px bg-gradient-to-r from-gold/40 via-gold/20 to-transparent" aria-hidden="true" />
      {process.map((p, i) => (
        <div key={i} class="text-center relative z-10">
          <div class="w-12 h-12 rounded-full bg-raised border border-default flex items-center justify-center mx-auto mb-4">
            <span class="font-grotesk font-bold text-sm text-primary">{p.step}</span>
          </div>
          <h3 class="font-grotesk font-semibold text-base text-primary mb-2">{p.title}</h3>
          <p class="text-xs text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Impact</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Results That <span class="gradient-gold">Grow</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Real results from real projects — data that proves the impact of premium web development.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((b, i) => (
        <div key={i} class="card card-hover p-6 lg:p-7 text-center">
          <b.icon class="w-8 h-8 text-gold mx-auto mb-4" />
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold mb-1">{b.value}</div>
          <div class="text-sm font-grotesk font-semibold text-primary mb-2">{b.label}</div>
          <p class="text-xs text-muted">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20" id="faq">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">FAQ</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Questions? <span class="gradient-gold">Answered.</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Everything you need to know about our web development service.</p>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-card" key={i}><summary>{faq.q}</summary><div class="faq-answer">{faq.a}</div></details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="card card-hover p-10 lg:p-14 text-center border-gold/20 max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Ready to <span class="gradient-gold">Launch</span> Your Site?</h2>
      <p class="text-base text-secondary mt-4 max-w-xl mx-auto">Let's build a website that grows your business. Free consultation included.</p>
      <a href="/contact?type=premium" class="btn-primary inline-flex mt-6">Start Your Project <ArrowRight class="w-4 h-4 ml-2" /></a>
    </div>
  </section>
</Layout>
