---
import Layout from '../../layouts/Layout.astro';
import { Search, TrendingUp, FileText, Link2, BarChart3, Eye, PenTool, LineChart, ArrowRight } from 'lucide-react';

const features = [
  { icon: Search, title: "Keyword Intelligence", desc: "AI-driven keyword research that finds high-opportunity terms your competitors missed. Cluster, prioritize, and track them automatically." },
  { icon: FileText, title: "Blog Automation", desc: "AI generates SEO-optimized blog posts from your strategy. Customizable tone, structured data, and internal linking built-in." },
  { icon: TrendingUp, title: "SERP Tracking", desc: "Real-time rank tracking for all your keywords. Daily updates with Google position, local packs, featured snippets, and visibility trends." },
  { icon: Link2, title: "Backlink Monitoring", desc: "Track every backlink, lost link, and competitor move. Get alerts for new opportunities and toxic links." },
  { icon: Eye, title: "Competitor Analysis", desc: "AI monitors your competitors' content strategy, keyword targets, and backlink profile. Know their moves before they matter." },
  { icon: BarChart3, title: "Technical SEO", desc: "Automated site audits, Core Web Vitals monitoring, structured data validation, and crawl optimization — all on autopilot." },
  { icon: PenTool, title: "Content Optimization", desc: "AI suggests content improvements based on top-ranking pages. Title tags, meta descriptions, headers, and readability scores." },
  { icon: LineChart, title: "SEO Reports", desc: "Automated weekly/monthly reports with key metrics, trends, and actionable recommendations delivered to your inbox." },
];

const process = [
  { step: "01", title: "SEO Audit", desc: "Full site audit covering technical SEO, content gaps, and competitor landscape." },
  { step: "02", title: "Keyword Strategy", desc: "AI identifies high-opportunity keywords clustered by intent and search volume." },
  { step: "03", title: "Content Engine", desc: "Auto-generate optimized content at scale with AI writing and structured data." },
  { step: "04", title: "Technical Fixes", desc: "Automated implementation of technical SEO improvements and Core Web Vitals." },
  { step: "05", title: "Monitor & Grow", desc: "Continuous SERP tracking, backlink monitoring, and strategy refinement." },
];

const benefits = [
  { icon: BarChart3, value: "300%", label: "Organic Traffic Growth", desc: "Average traffic increase within 6 months of implementing our SEO engine." },
  { icon: Eye, value: "850+", label: "Keywords Ranked", desc: "Average number of keywords our clients rank for in the top 10 positions." },
  { icon: FileText, value: "10x", label: "Content Output", desc: "Generate 10x more SEO-optimized content without increasing headcount." },
  { icon: TrendingUp, value: "40%", label: "Conversion Uplift", desc: "Better traffic quality and optimized pages drive measurable conversion gains." },
];

const faqs = [
  { q: "How is this different from traditional SEO?", a: "Traditional SEO is manual and slow. Our AI engine automates research, content creation, tracking, and optimization — delivering results in weeks, not months." },
  { q: "Will AI-generated content rank well?", a: "Yes, when done right. Our AI is trained on top-ranking content patterns, follows EEAT guidelines, and includes human oversight for quality assurance." },
  { q: "Do I need to provide content topics?", a: "No. The AI researches your niche, identifies gaps, and suggests topics that have high ranking potential. You approve before any content is published." },
  { q: "Can you fix my existing site's SEO?", a: "Absolutely. We start with a comprehensive audit, then systematically fix technical issues, optimize existing content, and build a content growth engine." },
  { q: "How long until I see results?", a: "Technical improvements show impact in 2-4 weeks. Content-driven rankings typically improve in 2-3 months. Sustained growth compounds over time." },
  { q: "What tools do you use?", a: "We use a custom AI stack built on GPT-4, vector search for content analysis, custom SERP scrapers, and integrations with Google Search Console and Analytics." },
];
---

<Layout title="SEO Automation Engine | LaunchWithAryan AI"
  description="AI-powered SEO automation for content strategy, SERP tracking, competitor analysis, and ranking growth. Rank higher. Grow faster.">

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-16">
    <div class="max-w-3xl">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">SEO Automation Service</p>
      <h1 class="text-3xl sm:text-4xl lg:text-5xl font-grotesk font-bold tracking-tight leading-[1.1] text-primary">
        Rank Higher. <span class="gradient-gold">Grow Faster.</span>
      </h1>
      <p class="text-base sm:text-lg text-secondary mt-4 max-w-2xl">
        AI-powered SEO automation for content strategy, SERP tracking, competitor analysis, and ranking growth. Turn search into your biggest growth channel.
      </p>
      <a href="/contact?type=premium" class="btn-primary text-base inline-flex mt-6">
        Start Your Project <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">AI-Powered <span class="gradient-gold">SEO Engine</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">An automated SEO system that researches, creates, optimizes, and tracks — so you dominate search results.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {features.map((f, i) => (
        <div key={i} class="card card-hover p-6 lg:p-7">
          <div class="w-10 h-10 rounded-xl bg-raised border border-default flex items-center justify-center text-gold mb-4">
            <f.icon class="w-5 h-5" />
          </div>
          <h3 class="font-grotesk font-semibold text-lg text-primary mb-3">{f.title}</h3>
          <p class="text-sm text-secondary leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Audit to <span class="gradient-gold">Dominance</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">From audit to dominance — a systematic approach to SEO automation that delivers measurable results.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 relative max-w-5xl mx-auto">
      <div class="hidden lg:block absolute top-6 left-[10%] right-[10%] h-px bg-gradient-to-r from-gold/40 via-gold/20 to-transparent" aria-hidden="true" />
      {process.map((p, i) => (
        <div key={i} class="text-center relative z-10">
          <div class="w-12 h-12 rounded-full bg-raised border border-default flex items-center justify-center mx-auto mb-4">
            <span class="font-grotesk font-bold text-sm text-primary">{p.step}</span>
          </div>
          <h3 class="font-grotesk font-semibold text-base text-primary mb-2">{p.title}</h3>
          <p class="text-xs text-muted leading-relaxed">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Impact</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Data That <span class="gradient-gold">Proves Results</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Real metrics from real campaigns — see what SEO automation delivers for our clients.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((b, i) => (
        <div key={i} class="card card-hover p-6 lg:p-7 text-center">
          <b.icon class="w-8 h-8 text-gold mx-auto mb-4" />
          <div class="text-3xl lg:text-4xl font-grotesk font-bold gradient-gold mb-1">{b.value}</div>
          <div class="text-sm font-grotesk font-semibold text-primary mb-2">{b.label}</div>
          <p class="text-xs text-muted">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20" id="faq">
    <div class="text-center mb-12">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">FAQ</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Questions? <span class="gradient-gold">Answered.</span></h2>
      <p class="text-base text-secondary mt-3 max-w-2xl mx-auto">Everything you need to know about our SEO automation service.</p>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq, i) => (
        <details class="faq-card" key={i}><summary>{faq.q}</summary><div class="faq-answer">{faq.a}</div></details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 lg:py-20">
    <div class="card card-hover p-10 lg:p-14 text-center border-gold/20 max-w-4xl mx-auto">
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">Ready to <span class="gradient-gold">Dominate</span> Search?</h2>
      <p class="text-base text-secondary mt-4 max-w-xl mx-auto">Let's build your SEO automation engine. Free consultation included.</p>
      <a href="/contact?type=premium" class="btn-primary inline-flex mt-6">Start Your Project <ArrowRight class="w-4 h-4 ml-2" /></a>
    </div>
  </section>
</Layout>
