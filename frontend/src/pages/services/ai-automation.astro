---
import Layout from '../../layouts/Layout.astro';
import ServiceHero from '../../components/ServiceHero.tsx';
import { Bot, Workflow, Database, Mail, HeadphonesIcon, BarChart3, Server, Zap, ArrowRight, CheckCircle, Clock, TrendingUp, Users, DollarSign } from 'lucide-react';

const features = [
  { icon: Bot, title: "AI Agents", desc: "Autonomous AI agents that handle lead qualification, data entry, scheduling, and follow-ups 24/7 without human supervision." },
  { icon: Workflow, title: "Workflow Automation", desc: "Connect your tools into seamless automated workflows. Trigger actions across platforms based on real-time events." },
  { icon: Database, title: "CRM Integration", desc: "Sync contacts, deals, and activities automatically. Keep your CRM updated without manual data entry." },
  { icon: Mail, title: "Email Automation", desc: "Smart email sequences that adapt to recipient behavior. Personalized outreach at scale with AI copywriting." },
  { icon: HeadphonesIcon, title: "Support Automation", desc: "AI-powered ticket triage, auto-responses, and escalation routing. Resolve 70% of queries without human touch." },
  { icon: BarChart3, title: "Reporting Dashboard", desc: "Real-time analytics on automation performance, cost savings, response times, and pipeline impact." },
  { icon: Server, title: "Lead Qualification", desc: "AI scores and categorizes leads based on intent signals, engagement data, and buyer persona matching." },
  { icon: Zap, title: "Smart Analytics", desc: "Actionable insights from your automation data. Identify bottlenecks, optimize flows, and measure ROI." },
];

const process = [
  { step: "01", title: "Discovery Audit", desc: "We map your current workflows, identify bottlenecks, and find the highest-ROI automation opportunities." },
  { step: "02", title: "Architecture Design", desc: "Blueprint the AI agent system, tool integrations, data flow, and failover protocols." },
  { step: "03", title: "Agent Development", desc: "Build and train custom AI agents with your data. Connect CRMs, email, Slack, and APIs." },
  { step: "04", title: "Testing & Tuning", desc: "Rigorously test every workflow. Tune accuracy, response times, and edge cases." },
  { step: "05", title: "Deploy & Monitor", desc: "Launch into production with 24/7 monitoring, alerts, and continuous optimization." },
];

const benefits = [
  { icon: Clock, value: "10x", label: "Faster Workflows", desc: "Automate repetitive tasks that used to take hours — now done in minutes." },
  { icon: DollarSign, value: "60%", label: "Cost Reduction", desc: "Slash operational costs by automating manual processes across your team." },
  { icon: TrendingUp, value: "85%", label: "Lead Response Speed", desc: "AI qualifies and responds to leads within seconds, not hours." },
  { icon: Users, value: "70%", label: "Ticket Automation", desc: "Support tickets resolved without human intervention, freeing your team." },
];

const faqs = [
  { q: "What types of workflows can you automate?", a: "Anything repetitive — lead qualification, email sequences, CRM updates, invoice processing, support ticket triage, reporting, and data sync between tools." },
  { q: "How long does it take to set up an automation?", a: "Most single-workflow automations are live within 2 weeks. Complex multi-agent systems take 3-5 weeks depending on integration depth." },
  { q: "Do I need technical knowledge to manage it?", a: "No. You get a dashboard to monitor performance. We handle all setup, maintenance, and tuning." },
  { q: "What platforms do you integrate with?", a: "50+ tools including HubSpot, Salesforce, Slack, Gmail, WhatsApp, Zapier, Notion, Stripe, Shopify, and custom REST/SOAP APIs." },
  { q: "Is my data secure?", a: "Yes. All data is encrypted in transit and at rest. We implement 7-layer security including SSTI/SQLi/LPDOS protection and HMAC-signed webhooks." },
  { q: "What's the ROI timeline?", a: "Most clients see full ROI within 60-90 days. Typical monthly savings range from $5,000 to $25,000 depending on automation scope." },
];
---

<Layout title="AI Automation Workflows | LaunchWithAryan AI"
  description="Build AI systems that automate lead generation, customer support, CRM updates, reporting, and complex workflows. Save 10x time with enterprise-grade AI automation.">

  <ServiceHero title="Automate Your Business." highlight="Scale Without Chaos."
    desc="Build AI systems that automate lead generation, customer support, CRM updates, reporting, and repetitive operations. Save 10x time with enterprise-grade reliability."
    badge="AI Automation Service" ctaUrl="/contact?type=premium">

    <div class="flex flex-col items-center justify-center text-center py-8 lg:py-12">
      <div class="w-48 h-48 lg:w-56 lg:h-56">
        <img src="/images/service-automation.svg" alt="AI Workflow Automation" class="w-full h-full object-contain" loading="lazy" />
      </div>
    </div>
  </ServiceHero>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">What We Do</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        AI <span class="gradient-gold">Workflow Automation</span>
      </h2>
      <p class="text-base text-secondary mt-3">We design, build, and deploy custom AI agents that connect your tools, automate your operations, and scale your business.</p>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-5">
      <div class="card p-6"><h3 class="font-grotesk font-semibold text-sm text-primary mb-2">🔍 Audit</h3><p class="text-xs text-secondary">We analyze your current workflows to find every manual process that can be automated.</p></div>
      <div class="card p-6"><h3 class="font-grotesk font-semibold text-sm text-primary mb-2">🔧 Build</h3><p class="text-xs text-secondary">Custom AI agents are developed and trained on your specific business data and processes.</p></div>
      <div class="card p-6"><h3 class="font-grotesk font-semibold text-sm text-primary mb-2">🔗 Integrate</h3><p class="text-xs text-secondary">Seamless connection with your existing tools — CRM, email, Slack, WhatsApp, and more.</p></div>
      <div class="card p-6"><h3 class="font-grotesk font-semibold text-sm text-primary mb-2">📊 Optimize</h3><p class="text-xs text-secondary">Continuous monitoring and tuning to maximize performance and ROI.</p></div>
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Features</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Everything You Need to <span class="gradient-gold">Automate</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {features.map((f) => (
        <div class="card card-hover p-6 lg:p-7">
          <div class="w-10 h-10 rounded-xl bg-raised border border-default flex items-center justify-center mb-4">
            <f.icon class="w-5 h-5 text-gold" />
          </div>
          <h3 class="font-grotesk font-semibold text-sm text-primary mb-2">{f.title}</h3>
          <p class="text-xs text-secondary leading-relaxed">{f.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">How It Works</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        From Discovery to <span class="gradient-gold">Deployment</span>
      </h2>
      <p class="text-base text-secondary mt-3">A proven 5-step process to automate your business.</p>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-8 relative max-w-5xl mx-auto">
      <div class="hidden lg:block absolute top-6 left-[10%] right-[10%] h-px bg-gradient-to-r from-gold/30 via-gold/10 to-transparent" aria-hidden="true" />
      {process.map((p) => (
        <div class="text-center relative z-10">
          <div class="w-12 h-12 rounded-full bg-raised border border-default flex items-center justify-center mx-auto mb-4">
            <span class="font-grotesk font-bold text-sm text-gold">{p.step}</span>
          </div>
          <h3 class="font-grotesk font-semibold text-sm text-primary mb-2">{p.title}</h3>
          <p class="text-xs text-muted leading-relaxed max-w-[180px] mx-auto">{p.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Impact</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Real Business <span class="gradient-gold">Results</span>
      </h2>
    </div>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {benefits.map((b) => (
        <div class="card card-hover p-7 text-center">
          <b.icon class="w-7 h-7 text-gold mx-auto mb-3" />
          <div class="text-2xl lg:text-3xl font-grotesk font-bold gradient-gold mb-1">{b.value}</div>
          <div class="text-sm font-medium text-primary mb-2">{b.label}</div>
          <p class="text-xs text-muted">{b.desc}</p>
        </div>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28" id="faq">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">FAQ</p>
      <h2 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Questions? <span class="gradient-gold">Answered.</span>
      </h2>
    </div>
    <div class="max-w-3xl mx-auto space-y-3">
      {faqs.map((faq) => (
        <details class="faq-card" key={faq.q}>
          <summary>{faq.q}</summary>
          <div class="faq-answer">{faq.a}</div>
        </details>
      ))}
    </div>
  </section>

  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="card card-hover p-10 lg:p-14 text-center border-gold/20 max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-grotesk font-bold tracking-tight text-primary mb-4">
        Ready to <span class="gradient-gold">Automate</span> Your Business?
      </h2>
      <p class="text-base text-secondary max-w-xl mx-auto mb-6">
        Let's map out your automation roadmap. Free consultation with our AI team.
      </p>
      <a href="/contact?type=premium" class="btn-primary inline-flex">
        Book Free Call <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </section>
</Layout>
