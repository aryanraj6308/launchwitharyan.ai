---
import Layout from '../layouts/Layout.astro';
import { LogIn } from 'lucide-react';
---

<Layout title="Login — Client Console | LaunchWithAryan AI">
  <section class="min-h-[70vh] flex items-center justify-center py-20">
    <div class="w-full max-w-md mx-auto px-4">
      <div class="card p-8 sm:p-10 space-y-6">
        <div class="text-center space-y-2">
          <div class="w-12 h-12 rounded-full bg-gold/20 flex items-center justify-center mx-auto">
            <LogIn class="w-5 h-5 text-gold" />
          </div>
          <h1 class="text-xl font-grotesk font-bold text-primary">Client Console</h1>
          <p class="text-xs text-muted">Sign in to manage your downloads and API configuration.</p>
        </div>

        <form method="POST" action="/api/auth/login" class="space-y-4">
          <div class="space-y-1.5">
            <label for="email" class="text-xs text-muted uppercase tracking-wider font-medium">Email</label>
            <input type="email" id="email" name="email" required placeholder="name@company.com" />
          </div>
          <div class="space-y-1.5">
            <label for="password" class="text-xs text-muted uppercase tracking-wider font-medium">Password</label>
            <input type="password" id="password" name="password" required placeholder="••••••••" />
          </div>
          <button type="submit" class="w-full btn-primary justify-center text-sm py-3">
            <LogIn class="w-4 h-4" />
            Sign In
          </button>
        </form>

        <p class="text-center text-xs text-muted">
          No account? <a href="/dashboard" class="text-gold hover:text-gold-dim underline">Go to Dashboard</a> to access the sandbox.
        </p>
      </div>
    </div>
  </section>
</Layout>
