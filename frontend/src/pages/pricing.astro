---
import Layout from '../layouts/Layout.astro';
import { Check, ShieldAlert, Zap, Globe, MessageSquare } from 'lucide-react';

const plans = [
  {
    name: "Starter AI Automation",
    price: "199",
    billing: "per month",
    icon: Zap,
    desc: "Perfect for growing teams looking to automate manual daily tasks.",
    features: [
      "Access to AI Prompt Library",
      "Standard Webhook pipelines",
      "Email support (24h turnaround)",
      "1 Custom chatbot instance"
    ],
    popular: false,
    cta: "Select Starter Tier"
  },
  {
    name: "Growth Engine Pro",
    price: "499",
    billing: "per month",
    icon: MessageSquare,
    desc: "For digital businesses looking to deploy bespoke intelligence models.",
    features: [
      "Full AI templates & Store access",
      "Private API hosting endpoint",
      "Secure Supabase RAG setup",
      "Dedicated Slack consulting channel",
      "Priority feature implementation"
    ],
    popular: true,
    cta: "Select Growth Tier"
  },
  {
    name: "Bespoke Enterprise Custom",
    price: "1,299",
    billing: "per month",
    icon: Globe,
    desc: "Custom deployment scripts and dedicated maintenance retainers.",
    features: [
      "Unlimited custom AI integrations",
      "Offline local LLM cluster setup",
      "Full custom design & development",
      "1-on-1 technical review calls",
      "Zero IP leakage guarantee"
    ],
    popular: false,
    cta: "Contact Architecture Team"
  }
];
---

<Layout title="Premium Automation Subscriptions | LaunchWithAryan AI">
  
  <section class="relative overflow-hidden py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      {/* Page Header */}
      <div class="text-center max-w-3xl mx-auto mb-20 space-y-4">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-elevated border border-subtle text-xs text-theme-secondary backdrop-blur-md">
          <span>Investment Structure</span>
        </div>
        <h1 class="text-4xl sm:text-5xl font-grotesk font-bold text-theme-primary tracking-tight">
          Flexible Plans for <span class="gradient-text">Uncapped Growth</span>
        </h1>
        <p class="text-theme-secondary font-sans leading-relaxed text-base">
          Choose a premium membership model that fits your operational needs, or consult directly with our core engineering team for bespoke developments.
        </p>
      </div>

      {/* Pricing Grid */}
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-20 items-stretch">
        {plans.map((plan) => {
          const Icon = plan.icon;
          return (
            <div class={`glass rounded-3xl p-8 sm:p-10 border flex flex-col justify-between relative ${
              plan.popular 
                ? 'border-primary/50 bg-gradient-to-b from-primary/5 via-transparent to-transparent shadow-xl shadow-primary/5 scale-105 z-10' 
                : 'border-subtle hover:border-subtle'
            } transition-all duration-300`}>
              
              {plan.popular && (
                <div class="absolute -top-3.5 left-1/2 transform -translate-x-1/2 px-4 py-1 rounded-full bg-primary text-[10px] font-bold uppercase tracking-wider text-white">
                  Most Requested Tier
                </div>
              )}

              <div class="space-y-6">
                <div class="flex items-center gap-3">
                  <div class={`w-10 h-10 rounded-xl flex items-center justify-center ${plan.popular ? 'bg-primary/25 text-primary' : 'bg-elevated text-theme-secondary'}`}>
                    <Icon class="w-5 h-5" />
                  </div>
                  <h3 class="text-lg font-grotesk font-semibold text-theme-primary">{plan.name}</h3>
                </div>

                <p class="text-xs text-theme-secondary font-sans leading-relaxed">{plan.desc}</p>

                {/* Price block */}
                <div class="pt-4 flex items-baseline gap-1 text-theme-primary">
                  <span class="text-3xl sm:text-4xl font-grotesk font-bold">${plan.price}</span>
                  <span class="text-xs text-theme-muted font-medium font-sans">/ {plan.billing}</span>
                </div>

                {/* Features List */}
                <ul class="space-y-3.5 pt-4 border-t border-subtle">
                  {plan.features.map((feat) => (
                    <li class="flex items-start gap-2.5 text-xs text-theme-secondary font-sans">
                      <Check class="w-4 h-4 text-primary flex-shrink-0 mt-0.5" />
                      <span>{feat}</span>
                    </li>
                  ))}
                </ul>
              </div>

              {/* Action Button */}
              <div class="pt-8">
                <a
                  href="/contact"
                  class={`w-full inline-flex items-center justify-center px-5 py-3 rounded-xl font-sans text-xs font-semibold tracking-wide transition-all duration-300 text-center ${
                    plan.popular
                      ? 'bg-primary hover:bg-primary-dark text-white hover:shadow-lg hover:shadow-primary/25'
                      : 'bg-elevated hover:bg-hover border border-subtle hover:border-subtle text-theme-primary'
                  }`}
                >
                  {plan.cta}
                </a>
              </div>

            </div>
          );
        })}
      </div>

    </div>
  </section>

</Layout>
