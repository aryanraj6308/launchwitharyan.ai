---
import Layout from '../layouts/Layout.astro';
import { Check, ArrowRight } from 'lucide-react';

const plans = [
  {
    name: "Starter",
    usd: "2,499",
    inr: "2,07,000",
    desc: "Best for startups launching their first AI workflow or web platform.",
    features: [
      "1 AI workflow or landing page",
      "Basic CRM + WhatsApp bot integration",
      "SEO-optimized (on-page)",
      "1 revision round",
      "2-week delivery",
      "30-day post-launch support"
    ],
    popular: false,
    cta: "Get Started",
    href: "/contact"
  },
  {
    name: "Growth",
    usd: "4,999",
    inr: "4,15,000",
    desc: "For growing teams scaling operations with AI automation.",
    features: [
      "3 AI workflows or multi-page site",
      "Full CRM + WhatsApp bot + analytics",
      "AI content generation (5 posts/mo)",
      "3 revision rounds",
      "3-week delivery",
      "Priority support",
      "Dedicated Slack channel"
    ],
    popular: true,
    cta: "Get Started",
    href: "/contact"
  },
  {
    name: "Enterprise",
    usd: "9,999",
    inr: "8,30,000",
    desc: "Custom solutions for large-scale AI deployments.",
    features: [
      "Unlimited AI workflows",
      "Custom integrations & API access",
      "Dedicated project manager",
      "SLA-backed uptime guarantee",
      "Security audit & penetration test",
      "Ongoing optimization",
      "Offline LLM cluster setup available"
    ],
    popular: false,
    cta: "Contact Sales",
    href: "/contact"
  }
];

const faqs = [
  { q: "What's included in the price?", a: "Every plan includes strategy design, development, testing, deployment, and 30 days of post-launch monitoring. No hidden fees." },
  { q: "Can I upgrade plans later?", a: "Yes. You can start with Starter and upgrade to Growth or Enterprise at any time. We'll credit your remaining balance toward the upgrade." },
  { q: "Do you offer ongoing support after launch?", a: "Yes. All plans include 30 days of post-launch support. We also offer maintenance plans for ongoing AI model retraining, content updates, and performance optimization." },
  { q: "What payment methods do you accept?", a: "We accept bank transfers, Razorpay (UPI, cards, netbanking), and Stripe (international cards). Invoicing available for Enterprise clients." },
];
---

<Layout title="Transparent Pricing | AryanForge">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Investment</p>
      <h1 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Transparent <span class="gradient-gold">Project Pricing</span>
      </h1>
      <p class="text-base text-secondary mt-3">Fixed-price packages with no hidden fees. Every plan includes deployment and 30-day support. <span class="text-gold font-medium">Not sure? Book a free discovery call.</span></p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 max-w-5xl mx-auto mb-20">
      {plans.map((plan) => (
        <div key={plan.name} class={`card card-hover p-7 lg:p-8 flex flex-col relative ${plan.popular ? 'border-gold/30 ring-1 ring-gold/20' : ''}`}>
          {plan.popular && (
            <span class="inline-flex self-start px-3 py-1 rounded-full text-[10px] font-semibold text-darkbg bg-gold mb-4">
              Most Popular
            </span>
          )}
          <h3 class="font-grotesk font-semibold text-lg text-primary">{plan.name}</h3>
          <div class="mt-3 mb-1">
            <span class="text-2xl lg:text-3xl font-grotesk font-bold text-primary">
              <span class="price-symbol" data-currency-symbol="$">$</span><span class="price-value" data-inr={plan.inr} data-usd={plan.usd}>{plan.usd}</span>
            </span>
            {plan.name !== 'Enterprise' && <span class="text-sm text-muted"> / project</span>}
          </div>
          <p class="text-sm text-muted mb-6">{plan.desc}</p>
          <ul class="space-y-2.5 mb-8 flex-1">
            {plan.features.map((f) => (
              <li key={f} class="flex items-start gap-2.5 text-sm text-secondary">
                <Check class="w-4 h-4 text-gold shrink-0 mt-0.5" />
                {f}
              </li>
            ))}
          </ul>
          <a href={plan.href} class={`block text-center py-2.5 px-5 rounded-xl text-sm font-semibold transition-all duration-200 ${plan.popular ? 'btn-primary justify-center' : 'btn-secondary justify-center'}`}>
            {plan.cta} <ArrowRight class="w-4 h-4" />
          </a>
        </div>
      ))}
    </div>

    <!-- Enterprise CTA -->
    <div class="cta-section max-w-4xl mx-auto">
      <h2 class="text-2xl sm:text-3xl font-grotesk font-bold tracking-tight text-primary mb-3">
        Need Something <span class="gradient-gold">Bespoke</span>?
      </h2>
      <p class="text-sm text-secondary max-w-xl mx-auto mb-6">
        Custom AI models, offline LLM clusters, multi-agent orchestration, or enterprise-wide automation? We'll scope it in a free technical review.
      </p>
      <a href="/contact" class="btn-primary text-base inline-flex min-h-[48px]">
        Book a Free Discovery Call <ArrowRight class="w-4 h-4" />
      </a>
    </div>

    <!-- FAQ -->
    <div class="max-w-3xl mx-auto mt-28">
      <h2 class="text-xl sm:text-2xl font-grotesk font-bold tracking-tight text-primary text-center mb-10">
        Pricing <span class="gradient-gold">FAQs</span>
      </h2>
      <div class="space-y-3">
        {faqs.map((faq) => (
          <details key={faq.q} class="faq-card">
            <summary>{faq.q}</summary>
            <div class="faq-answer">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script>
    function updatePrices() {
      const currency = localStorage.getItem('preferred_currency') || 'USD';
      document.querySelectorAll('.price-value').forEach(el => {
        const symbol = el.closest('[data-price]')?.querySelector('.price-symbol') || el.parentElement.querySelector('.price-symbol');
        const inr = el.dataset.inr;
        const usd = el.dataset.usd;
        if (currency === 'INR') {
          el.textContent = inr;
          if (symbol) symbol.textContent = '₹';
        } else {
          el.textContent = usd;
          if (symbol) symbol.textContent = '$';
        }
      });
    }
    updatePrices();
    window.addEventListener('currencyChange', updatePrices);
  </script>
</Layout>
