---
import Layout from '../layouts/Layout.astro';
import { Check, Zap, MessageSquare, Globe } from 'lucide-react';

const plans = [
  {
    name: "Starter",
    price: "199",
    billing: "per month",
    icon: Zap,
    desc: "Perfect for growing teams looking to deploy a chatbot or simple AI tool.",
    features: [
      "Access to AI Prompt Library",
      "Standard Webhook pipelines",
      "Email support (24h turnaround)",
      "1 Custom chatbot instance"
    ],
    popular: false,
    cta: "Get Quick Quote",
    href: "/contact?type=quick&source=starter"
  },
  {
    name: "Growth Engine",
    price: "499",
    billing: "per month",
    icon: MessageSquare,
    desc: "For digital businesses looking to deploy full AI automation workflows.",
    features: [
      "Full AI templates & Store access",
      "Private API hosting endpoint",
      "Secure Supabase RAG setup",
      "Dedicated Slack consulting channel",
      "Priority feature implementation"
    ],
    popular: true,
    cta: "Book Premium Discovery",
    href: "/contact?type=premium&source=growth"
  },
  {
    name: "Enterprise",
    price: "1,299",
    billing: "per month",
    icon: Globe,
    desc: "Custom enterprise automation with dedicated infrastructure and team.",
    features: [
      "Unlimited custom AI integrations",
      "Offline local LLM cluster setup",
      "Full custom design & development",
      "1-on-1 technical review calls",
      "Zero IP leakage guarantee"
    ],
    popular: false,
    cta: "Book Strategy Call",
    href: "/contact?type=premium&source=enterprise"
  }
];
---

<Layout title="Premium Automation Subscriptions | LaunchWithAryan AI">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Investment Structure</p>
      <h1 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Flexible Plans for <span class="gradient-gold">Uncapped Growth</span>
      </h1>
      <p class="text-base text-secondary mt-3">Choose a premium membership model that fits your operational needs, or consult directly with our core engineering team for bespoke developments.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-stretch">
      {plans.map((plan) => {
        const Icon = plan.icon;
        return (
          <div class={`card card-hover p-7 lg:p-8 flex flex-col justify-between relative ${
            plan.popular ? 'border-gold/30 ring-1 ring-gold/20' : ''
          }`}>
            {plan.popular && (
              <div class="absolute -top-3 left-1/2 -translate-x-1/2 px-3 py-1 rounded-full bg-gold text-[10px] font-bold uppercase tracking-wider text-darkbg whitespace-nowrap">
                Most Requested Tier
              </div>
            )}

            <div>
              <div class="flex items-center gap-3 mb-4">
                <div class="w-9 h-9 rounded-lg bg-raised border border-default flex items-center justify-center text-gold">
                  <Icon class="w-4.5 h-4.5" />
                </div>
                <h3 class="font-grotesk font-semibold text-primary">{plan.name}</h3>
              </div>

              <p class="text-sm text-secondary mb-4">{plan.desc}</p>

              <div class="mb-5">
                <span class="text-2xl lg:text-3xl font-grotesk font-bold text-primary">${plan.price}</span>
                <span class="text-sm text-muted"> / {plan.billing}</span>
              </div>

              <ul class="space-y-2.5 border-t border-default pt-5">
                {plan.features.map((feat) => (
                  <li class="flex items-start gap-2.5 text-sm text-secondary">
                    <Check class="w-4 h-4 text-gold shrink-0 mt-0.5" />
                    <span>{feat}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-8">
              <a href={plan.href} class={`w-full inline-flex items-center justify-center px-5 py-2.5 rounded-xl text-sm font-semibold transition-all duration-200 ${
                plan.popular
                  ? 'btn-primary'
                  : 'btn-secondary'
              }`}>
                {plan.cta}
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>
