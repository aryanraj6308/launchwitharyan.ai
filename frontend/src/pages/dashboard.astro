---
import Layout from '../layouts/Layout.astro';
import DashboardLayout from '../components/DashboardLayout.tsx';
---

<Layout title="Client Console Dashboard | AryanForge">
  
  <section class="relative overflow-hidden py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      {/* Page Header */}
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Secure Console</p>
        <h1 class="text-4xl sm:text-5xl font-grotesk font-bold text-primary tracking-tight">
          Your Workspace <span class="gradient-gold">Dashboard</span>
        </h1>
        <p class="text-secondary font-sans leading-relaxed text-base">
          Configure API connections, manage your downloadable templates, and check token rate telemetry.
        </p>
      </div>

      {/* Dashboard container */}
      <DashboardLayout client:only="react" />

    </div>
  </section>

</Layout>
