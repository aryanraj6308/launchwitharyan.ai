---
import Layout from '../layouts/Layout.astro';
import { Bot, Code, LineChart, Cpu, Shield, ArrowRight } from 'lucide-react';

const services = [
  {
    icon: Bot,
    title: "AI Workflows & Automation",
    subtitle: "Eliminate repetitive tasks and save hundreds of employee hours.",
    features: [
      "Secure custom LLM fine-tuning",
      "Dynamic prompt engineering pipelines",
      "API connections to Slack, Notion, Gmail, and CRMs",
      "Multi-agent collaborative systems"
    ],
    tech: "LangChain, Llama-3, Python, FastAPI"
  },
  {
    icon: Code,
    title: "Premium Bespoke Websites",
    subtitle: "High-end corporate storefronts designed to command premium pricing.",
    features: [
      "Light/dark mode premium design",
      "Optimized Core Web Vitals (95+ Lighthouse Score)",
      "Three.js/WebGL interactive animations",
      "Astro + React edge-rendered architectures"
    ],
    tech: "Astro, React, Tailwind, Framer Motion"
  },
  {
    icon: Shield,
    title: "Conversational AI Chatbots",
    subtitle: "24/7 client support and immediate lead qualification systems.",
    features: [
      "Custom vector database integration (RAG)",
      "Context-aware memory for continuous dialogues",
      "Secure payment processing via Stripe/Razorpay inline",
      "Auto-handoff trigger to human representatives"
    ],
    tech: "Supabase PGVector, OpenAI API, Ollama"
  },
  {
    icon: LineChart,
    title: "Programmatic SEO Automation",
    subtitle: "Generate hundreds of landing pages with high commercial intent automatically.",
    features: [
      "Dynamic JSON-LD Schema markup generator",
      "Automated XML sitemaps and indexing submissions",
      "Keyword mapping optimization engine",
      "Speed optimized static deployments to Vercel/Cloudflare"
    ],
    tech: "Node.js, Astro Static Routing, Google Index API"
  },
  {
    icon: Cpu,
    title: "Enterprise Business Workflows",
    subtitle: "Integrate database storage with custom interfaces for operations dashboards.",
    features: [
      "Supabase real-time sync systems",
      "Custom analytics widgets & reporting views",
      "Robust OAuth2 authentication & user controls",
      "Webhook trigger frameworks & queue logging"
    ],
    tech: "PostgreSQL, FastAPI, Supabase, JWT"
  }
];
---

<Layout title="AI Services & Solutions | LaunchWithAryan AI">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-28">
    <div class="max-w-2xl mb-14">
      <p class="text-xs font-semibold text-muted uppercase tracking-widest mb-3">Enterprise Engineering</p>
      <h1 class="text-3xl sm:text-4xl font-grotesk font-bold tracking-tight text-primary">
        Services Designed For <span class="gradient-gold">Hyper-Scale</span>
      </h1>
      <p class="text-base text-secondary mt-3">We combine local LLM hosting, premium web frontends, secure backend integrations, and automated pipelines to optimize your bottom line.</p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-20">
      {services.map((service) => {
        const Icon = service.icon;
        return (
          <div class="card card-hover p-7 lg:p-8 flex flex-col justify-between">
            <div>
              <div class="flex items-center gap-4 mb-5">
                <div class="w-10 h-10 rounded-xl bg-raised border border-default flex items-center justify-center text-gold">
                  <Icon class="w-5 h-5" />
                </div>
                <div>
                  <h2 class="font-grotesk font-semibold text-base text-primary">{service.title}</h2>
                  <p class="text-xs text-muted mt-0.5">{service.tech}</p>
                </div>
              </div>

              <p class="text-sm text-secondary mb-5">{service.subtitle}</p>

              <ul class="space-y-2.5">
                {service.features.map((feat) => (
                  <li class="flex items-start gap-2 text-sm text-secondary">
                    <span class="text-gold mt-0.5 text-sm font-bold">✓</span>
                    <span>{feat}</span>
                  </li>
                ))}
              </ul>
            </div>

            <div class="mt-6 pt-6 border-t border-default flex items-center justify-between">
              <span class="text-xs text-muted">Premium Tier Solution</span>
              <a href="/contact" class="inline-flex items-center gap-1 text-sm font-medium text-gold hover:text-gold-dim transition-colors">
                Configure Service <ArrowRight class="w-4 h-4" />
              </a>
            </div>
          </div>
        );
      })}
    </div>

    <div class="card card-hover p-8 lg:p-10 text-center max-w-3xl mx-auto border-gold/20">
      <h3 class="text-xl font-grotesk font-bold text-primary mb-3">Need a Bespoke RAG or Custom Fine-Tuning Setup?</h3>
      <p class="text-sm text-secondary max-w-xl mx-auto mb-6">
        We architect standalone offline AI clusters using local hardware or highly secure private cloud setups, ensuring zero intellectual property leakage.
      </p>
      <a href="/contact" class="btn-primary text-sm inline-flex">
        Book Technical Review <ArrowRight class="w-4 h-4" />
      </a>
    </div>
  </section>
</Layout>
