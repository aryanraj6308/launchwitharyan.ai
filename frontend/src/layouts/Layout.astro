---
import Navbar from '../components/Navbar.tsx';
import Footer from '../components/Footer.astro';
import ChatbotAI from '../components/ChatbotAI.tsx';
import CookieConsent from '../components/CookieConsent.tsx';
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
}

const {
  title = "AryanForge | Premium AI Automations & Web Platforms",
  description = "A premium luxury technology company crafting high-performance websites, AI systems, and digital tools for forward-thinking enterprises.",
  ogImage = "/images/og-image.svg",
  canonicalURL = Astro.url.href
} = Astro.props as Props;

const schemaMarkup = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "AryanForge",
  "url": "https://aryanforge.com",
  "logo": "https://aryanforge.com/logo.svg",
  "image": ogImage.startsWith('http') ? ogImage : `https://aryanforge.com${ogImage}`,
  "description": description,
  "foundingDate": "2025",
  "address": {
    "@type": "PostalAddress",
    "addressCountry": "IN"
  },
  "contactPoint": {
    "@type": "ContactPoint",
    "email": "aryan@launchwitharyan.ai",
    "contactType": "sales",
    "availableLanguage": ["English"]
  },
  "sameAs": [
    "https://aryanforge.com"
  ],
  "serviceType": [
    "AI Automation Services",
    "Premium Web Development",
    "AI Conversational Chatbots",
    "SEO Automation Engines"
  ],
  "priceRange": "$$$$"
};
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="keywords" content="AI automation, web development, chatbots, SEO automation, AI agents, lead generation, custom software" />
    <meta name="author" content="Aryan" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={ogImage} />
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <!-- AdSense: replace with your publisher ID when approved -->
    <!-- <meta name="google-adsense-account" content="ca-pub-xxxxxxxxxxxxxxxx" /> -->
    <link rel="sitemap" href="/sitemap-index.xml" />
    <script type="application/ld+json" is:raw set:html={JSON.stringify(schemaMarkup)} />
    <script is:inline>
      (function() {
        var theme = localStorage.getItem('theme') || 'dark';
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.setProperty('color-scheme', theme === 'light' ? 'light' : 'dark');
      })();
    </script>
  </head>
  <body class="gradient-bg-subtle min-h-screen antialiased flex flex-col justify-between">

    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:rounded-lg focus:bg-gold focus:text-darkbg focus:text-sm focus:font-medium">
      Skip to main content
    </a>

    <Navbar client:load />

    <main id="main-content" class="flex-grow pt-16">
      <slot />
    </main>

    <Footer />

    <ChatbotAI client:load />
    <CookieConsent client:load />
  </body>
</html>
